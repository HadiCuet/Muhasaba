  "settingsRolloverSub": "Kun qachon yangilanadi",
  "hadith10": "\"Kim kuniga yuz marta 'SubhanAllohi va bihamdihi' desa, uning gunohlari kechiriladi, hatto dengiz ko'pigi kabi bo'lsa ham.\"\n— Buxoriy",
  "hadith11": "\"Eng yaxshi duo — Arafa kunidagi duo, men va mendan oldingi payg'ambarlar aytgan eng yaxshi so'z: La ilaha illalloh.\"\n— Termiziy",
  "hadith12": "\"Kim har farz namazdan keyin Oyat al-Kursiy o'qisa, uni jannatga kirishdan faqat o'lim to'sqinlik qiladi.\"\n— Nasoiy",
  "hadith13": "\"Yaxshi so'z sadaqadir.\"\n— Buxoriy va Muslim",
  "hadith14": "\"Allohga va oxirat kuniga ishongan kishi yaxshi so'z aytsin yoki sukut saqlasin.\"\n— Buxoriy va Muslim",
  "hadith15": "\"Beva va miskinlarga g'amxo'rlik qiluvchi Alloh yo'lida kurashuvchi kabidur.\"\n— Buxoriy",
  "hadith16": "\"Birodaringga tabassum qilishing sadaqadir.\"\n— Termiziy",
  "hadith17": "\"Sizlarning eng yaxshingiz Qur'onni o'rganuvchi va o'rgatuvchidur.\"\n— Buxoriy",
  "hadith18": "\"Hech kim o'z qo'li mehnati bilan topganidan yaxshiroq taom yemagan.\"\n— Buxoriy",
  "hadith19": "\"Alloh yumshoq va har ishda yumshoqlikni sevadi.\"\n— Buxoriy va Muslim",
  "settingsAbout": "Haqida",
  "settingsVersion": "Versiya",
  "settingsDeveloper": "Dasturchi",
  "hadith50": "\"Allohga eng sevimli odamlar boshqalarga eng ko'p foyda keltiradigan odamlardir.\"\n— Tabaraniy",
  "hadith51": "\"Kim g'azabini bosib tursa, holbuki uni amalga oshira olsa, Alloh uni Qiyomat kuni barcha maxluqotlar oldida chaqirib, mukofotini tanlashini so'raydi.\"\n— Termiziy",
  "hadith52": "\"Sadaqa berishga shoshiling, chunki u balodan himoya qiladi.\"\n— Termiziy",
  "hadith53": "\"Hech qanday yaxshilikni kichik ko'rmang, hatto birodaringizni ochiq chehra bilan kutish bo'lsa ham.\"\n— Muslim",
  "hadith54": "\"Sizlarning eng yaxshingiz oilasiga eng yaxshi bo'lganingizdir.\"\n— Termiziy",
  "hadith55": "\"Kim kechasi Baqara surasining oxirgi ikki oyatini o'qisa, bu unga kifoya qiladi.\"\n— Buxoriy va Muslim",
  "hadith56": "\"Dunyo bir matoh, eng yaxshi matohi esa solih ayoldir.\"\n— Muslim",
  "hadith57": "\"Uchta duo rad etilmaydi: ro'za tutuvchining duosi, odil hukmdorning duosi va mazlumning duosi.\"\n— Termiziy",
  "hadith58": "\"Kim menga bir marta salavot aytsa, Alloh unga o'n marta rahmat yuboradi.\"\n— Muslim",
  "hadith59": "\"Masjid har bir taqvodor kishining uyidir.\"\n— Tabaraniy",
  "hadith60": "\"Kim 'La havla va la quvvata illa billah' desa — bu to'qson to'qqizta dardning davosidir, ularning eng yengili tashvishdir.\"\n— Hokim",
  "hadith61": "\"Alloh biror ish qilganingizda uni mukammal qilishingizni yaxshi ko'radi.\"\n— Tabaraniy",
  "hadith62": "\"Jannat onalarning oyoqlari ostidadir.\"\n— Nasoiy",
  "hadith63": "\"Ota-onaga yaxshilik qilish eng buyuk farz amaldir.\"\n— Buxoriy",
  "hadith64": "\"Kim ozga shukr qilsa, unga ko'p beriladi.\"\n— Bayhaqiy",
  "hadith65": "\"Mo'min mo'minning oynasi.\"\n— Abu Dovud",
  "hadith66": "\"Rostgo'ylik yaxshilikka olib boradi, yaxshilik esa jannatga olib boradi.\"\n— Buxoriy va Muslim",
  "hadith67": "\"Omonatni senga ishongan kishiga qaytar, senga xiyonat qilganga xiyonat qilma.\"\n— Abu Dovud va Termiziy",
  "hadith68": "\"Musulmonga yetadigan charchoq, kasallik, qayg'u, g'am, ozor yoki tashvish, hatto tikan kirib ketishi ham bo'lsa, Alloh buning evaziga uning gunohlaridan bir qismini kechiradi.\"\n— Buxoriy va Muslim",
  "hadith69": "\"Musulmonning g'oyibona birodariga qilgan duosi doimo ijobat bo'ladi.\"\n— Muslim",
  "hadith70": "\"Kim Allohdan uch marta jannat so'rasa, jannat aytadi: Ey Alloh, uni jannatga kirgazgil.\"\n— Termiziy",
  "hadith71": "\"Ramazondan keyingi eng fazilatli ro'za Allohning oyi Muharram oyining ro'zasidir.\"\n— Muslim",
  "hadith72": "\"Kim haj qilib, fahsh so'z aytmasa va gunoh qilmasa, onasi tug'gan kundagidek qaytadi.\"\n— Buxoriy va Muslim",
  "hadith73": "\"Bir umra ikkinchi umragacha orasidagi gunohlarning kafforatidir.\"\n— Buxoriy va Muslim",
  "hadith74": "\"Yaxshi ishlarga shoshiling.\"\n— Muslim",
  "hadith75": "\"Bomdod namozining ikki rakati dunyo va undagi barcha narsadan yaxshiroqdir.\"\n— Muslim",
  "hadith76": "\"Kim muntazam istig'for aytsa, Alloh unga har qiyinchilikdan chiqish yo'lini beradi.\"\n— Abu Dovud",
  "hadith77": "\"Agar sizlar Allohga to'g'ri tawaqqul qilganingizda, U sizlarni qushlarni rizqlantirganidek rizqlantirgan bo'lar edi.\"\n— Termiziy",
  "hadith78": "\"Kim bemorni ziyorat qilsa, qaytib kelguniga qadar jannat bog'ida bo'ladi.\"\n— Muslim",
  "hadith79": "\"Salomni yoying, taom bering va odamlar uxlaganda tungi namoz o'qing — jannatga tinchlik bilan kirarsiz.\"\n— Termiziy",
  "hadith80": "\"Allohga eng sevimli amal — doimiy bajariladigan amaldir, garchi oz bo'lsa ham.\"\n— Buxoriy",
  "hadith81": "\"Hasad faqat ikki holatda joiz: Alloh mol bergan va uni haq yo'lida sarflaydigan kishi, va Alloh hikmat bergan va u bilan hukm qiladigan hamda o'rgatadigan kishi.\"\n— Buxoriy va Muslim",
  "hadith82": "\"Inson do'stining dini ustidadir, shuning uchun har biringiz kim bilan do'stlashayotganiga qarasin.\"\n— Abu Dovud va Termiziy",
  "hadith83": "\"O'limni ko'p eslang, chunki u qalbni poklaydi.\"\n— Termiziy",
  "hadith84": "\"Sizlarning eng yaxshingiz qalbi eng yumshoq bo'lganidir.\"\n— Tabaroniy",
  "hadith85": "\"Alloh hech bir jonga uning toqatidan ortiq yuk yuklamaydi.\"\n— Qur'on 2:286",
  "hadith86": "\"Kim musulmonning aybini yashirsa, Alloh qiyomat kunida uning aybini yashiradi.\"\n— Buxoriy va Muslim",
  "hadith87": "\"Dunyoda begona yoki yo'lovchidek bo'l.\"\n— Buxoriy",
  "hadith88": "\"Kim qiyin ahvolda bo'lganga osonlik qilsa, Alloh unga dunyoda va oxiratda osonlik qiladi.\"\n— Muslim",
  "hadith89": "\"Amallar niyatlarga bog'liqdir.\"\n— Buxoriy va Muslim",
  "hadith90": "\"Gumondan saqlaning, chunki gumon eng yolg'on so'zdir.\"\n— Buxoriy va Muslim",
  "hadith91": "\"Kim Alloh uchun yolg'onni tark etsa, hazil paytida ham bo'lsa, men unga jannat chekkasida bir qasr kafolatini beraman.\"\n— Abu Dovud",
  "hadith92": "\"Yaxshilik eshiklari ko'p: Allohni ulug'lash, Unga hamd aytish, sadaqa, yaxshilikka buyurish va yo'ldan ozorni olib tashlash.\"\n— Muslim",
  "hadith93": "\"Birga ovqatlaning va Allohning nomini zikr qiling, sizlar uchun baraka bo'ladi.\"\n— Abu Dovud",
  "hadith94": "\"Eng yaxshi majlis — eng keng bo'lganidir.\"\n— Abu Dovud",
  "hadith95": "\"Kechiring, sizlar ham kechirilasiz.\"\n— Ahmad",
  "hadith96": "\"Tuyangni bog'la, keyin Allohga tavakqul qil.\"\n— Termiziy",
  "hadith97": "\"Mo'minning ishi ajoyib — hamma narsa unga yaxshi.\"\n— Muslim",
  "hadith98": "\"Musulmon musulmonning birodaradir: unga zulm qilmaydi, uni tashlab ketmaydi va uni kamsitmaydi.\"\n— Muslim",
  "hadith99": "\"Allohga eng sevimli so'z: SubhanAllohi va bihamdihi, SubhanAllohil Azim.\"\n— Buxoriy va Muslim",
  "hadith20": "\"Kim Ramazonni iymon bilan va savob umidida ro'za tutsa, uning o'tgan gunohlari kechiriladi.\"\n— Buxoriy va Muslim",
  "hadith21": "\"Namoz dinning ustunidur.\"\n— Bayhaqiy",
  "hadith22": "\"Azon va iqomat orasidagi duo rad etilmaydi.\"\n— Abu Dovud",
  "hadith23": "\"Kim Alloh uchun masjid qursa, Alloh unga jannatda uy quradi.\"\n— Buxoriy va Muslim",
  "hadith24": "\"Erkaklar uchun eng yaxshi saflar birinchi saflar, ayollar uchun eng yaxshi saflar oxirgi saflardir.\"\n— Muslim",
  "hadith25": "\"Ro'za do'zaxdan qalqondur.\"\n— Nasoiy",
  "hadith26": "\"Kim o'n ikki rak'at sunnat namazni o'qisa, unga jannatda uy quriladi.\"\n— Muslim",
  "hadith27": "\"Qur'onni yaxshi biladigan kishi oliy farishtalar bilan birga bo'ladi.\"\n— Buxoriy va Muslim",
  "hadith28": "\"Ilm o'rganish har bir musulmonga farzdir.\"\n— Ibn Moja",
  "hadith29": "\"Sadaqaning eng yaxshisi suv berishdur.\"\n— Ahmad",
  "hadith30": "\"Kim mo'mindan bir qiyinchilikni bartaraf qilsa, Alloh Qiyomat kunida undan bir qiyinchilikni bartaraf qiladi.\"\n— Muslim",
  "hadith31": "\"Rahm qiluvchilarga Rahmoni Rahim rahm qiladi.\"\n— Abu Dovud va Termiziy",
  "hadith32": "\"Hayo — imonning bir qismidur.\"\n— Buxoriy va Muslim",
  "hadith33": "\"Pokizalik — imonning yarmidir.\"\n— Muslim",
  "hadith34": "\"Kim sabr qilsa, Alloh unga sabr beradi.\"\n— Buxoriy va Muslim",
  "hadith35": "\"Eng yaxshi boylik — Allohni zikr qiluvchi tildir.\"\n— Tabaroniy",
  "hadith36": "\"Sizlardan hech biringiz o'zi uchun yaxshi ko'rgan narsani birodariga ham yaxshi ko'rmaguncha, haqiqiy mo'min bo'lmaydi.\"\n— Buxoriy va Muslim",
  "hadith37": "\"Ochlarni to'ydiringlar, bemorlarni ziyorat qilinglar va asirlarni ozod qilinglar.\"\n— Buxoriy",
  "hadith38": "\"Kuchli odam kurashda yengadigan emas, balki g'azab paytida o'zini tiya oladigan kishidir.\"\n— Buxoriy va Muslim",
  "hadith39": "\"Kim tilini va iffatini saqlasa, men unga jannatni kafolatlayman.\"\n— Buxoriy",
  "hadith40": "\"Har namazdan keyin o'ttiz uch marta 'SubhanAlloh', 'Alhamdulillah' va 'Allohu Akbar' deng.\"\n— Muslim",
  "hadith41": "\"Eng yaxshi zikr — La ilaha illalloh.\"\n— Termiziy",
  "hadith42": "\"Ikki ne'mat bor, ko'p odamlar ularni boy beradi: sog'lik va bo'sh vaqt.\"\n— Buxoriy",
  "hadith43": "\"Beshtani beshta kelmasdan oldin g'animat bilinglar: yoshlikni qarilikning, sog'likni kasallikning, boylikni qashshoqlikning, bo'sh vaqtni bandlikning va hayotni o'limning oldida.\"\n— Hokim",
  "hadith44": "\"Kim Ixlos surasini o'n marta o'qisa, Alloh unga jannatda uy quradi.\"\n— Ahmad",
  "hadith45": "\"Farz namazlaridan keyin eng yaxshi namoz — tungi namozdur.\"\n— Muslim",
  "hadith46": "\"Sadaqa gunohlarni suv o'tni o'chirganday o'chiradi.\"\n— Termiziy",
  "hadith47": "\"Silai rahm qiluvchi javob qaytaruvchi emas, balki qarishilmasa ham aloqani saqlovchidir.\"\n— Buxoriy",
  "hadith48": "\"Har bir yaxshi ish sadaqadur.\"\n— Buxoriy va Muslim",
  "hadith49": "\"Kim taom yeb, Alhamdulillah desa, uning o'tgan gunohlari kechiriladi.\"\n— Termiziy"
}
