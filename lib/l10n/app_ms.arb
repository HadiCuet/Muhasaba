  "hadith20": "\"Sesiapa yang berpuasa pada bulan Ramadan kerana iman dan mengharapkan pahala, dosa-dosanya yang lalu akan diampunkan.\"\n— Bukhari & Muslim",
  "hadith22": "\"Doa antara azan dan iqamah tidak ditolak.\"\n— Abu Dawud",
  "hadith23": "\"Sesiapa yang membina masjid kerana Allah, Allah akan membina untuknya sebuah rumah di syurga.\"\n— Bukhari & Muslim",
  "hadith24": "\"Saf yang terbaik bagi lelaki ialah saf yang pertama, dan saf yang terbaik bagi wanita ialah saf yang terakhir.\"\n— Muslim",
  "hadith25": "\"Puasa adalah perisai daripada api neraka.\"\n— Nasa'i",
  "hadith26": "\"Sesiapa yang menunaikan dua belas rakaat solat sunat, sebuah rumah akan dibina untuknya di syurga.\"\n— Muslim",
  "hadith27": "\"Orang yang mahir membaca al-Quran akan bersama para malaikat yang mulia.\"\n— Bukhari & Muslim",
  "hadith29": "\"Sedekah yang paling utama ialah memberi air minum.\"\n— Ahmad",
  "hadith30": "\"Sesiapa yang melepaskan kesusahan seorang mukmin, Allah akan melepaskan kesusahannya pada Hari Kiamat.\"\n— Muslim",
  "hadith32": "\"Malu adalah sebahagian daripada iman.\"\n— Bukhari & Muslim",
  "hadith34": "\"Sesiapa yang bersabar, Allah akan memberikan kesabaran kepadanya.\"\n— Bukhari & Muslim",
  "hadith36": "\"Tidak sempurna iman seseorang sehingga dia mencintai untuk saudaranya apa yang dia cintai untuk dirinya sendiri.\"\n— Bukhari & Muslim",
  "hadith37": "\"Berilah makan orang yang lapar, ziarahilah orang yang sakit, dan bebaskanlah tawanan.\"\n— Bukhari",
  "hadith38": "\"Orang yang kuat bukanlah yang menang dalam gusti, tetapi yang dapat mengawal dirinya ketika marah.\"\n— Bukhari & Muslim",
  "hadith40": "\"Ucapkanlah 'SubhanAllah', 'Alhamdulillah', dan 'Allahu Akbar' masing-masing tiga puluh tiga kali selepas setiap solat.\"\n— Muslim",
  "hadith41": "\"Zikir yang paling utama ialah La ilaha illallah.\"\n— Tirmizi",
  "hadith42": "\"Ada dua nikmat yang ramai manusia tertipu dengannya: kesihatan dan masa lapang.\"\n— Bukhari",
  "hadith43": "\"Manfaatkanlah lima perkara sebelum lima perkara: muda sebelum tua, sihat sebelum sakit, kaya sebelum miskin, lapang sebelum sibuk, dan hidup sebelum mati.\"\n— Hakim",
  "hadith44": "\"Sesiapa yang membaca Surah al-Ikhlas sepuluh kali, Allah akan membina untuknya sebuah rumah di syurga.\"\n— Ahmad",
  "hadith45": "\"Solat yang paling utama selepas solat fardhu ialah solat malam.\"\n— Muslim",
  "hadith46": "\"Sedekah memadamkan dosa sebagaimana air memadamkan api.\"\n— Tirmizi",
  "hadith47": "\"Orang yang menghubungkan silaturrahim bukanlah yang membalas. Tetapi dia adalah yang menghubungkannya walaupun dipinggirkan.\"\n— Bukhari",
  "hadith49": "\"Sesiapa yang makan lalu berkata: 'Segala puji bagi Allah yang telah memberi makan ini kepadaku dan mengurniainya tanpa sebarang daya dan kekuatan daripadaku,' dosa-dosa lamanya akan diampunkan.\"\n— Tirmizi",
  "hadith53": "\"Jangan meremehkan sebarang kebaikan, walaupun bertemu saudaramu dengan wajah yang ceria.\"\n— Muslim",
  "hadith54": "\"Sebaik-baik kamu ialah yang terbaik terhadap keluarganya.\"\n— Tirmizi",
  "hadith55": "\"Sesiapa yang membaca dua ayat terakhir Surah al-Baqarah pada waktu malam, ia memadai baginya.\"\n— Bukhari & Muslim",
  "hadith56": "\"Dunia adalah kesenangan, dan sebaik-baik kesenangan dunia ialah isteri yang solehah.\"\n— Muslim",
  "hadith57": "\"Tiga doa yang tidak ditolak: doa orang yang berpuasa, doa pemimpin yang adil, dan doa orang yang dizalimi.\"\n— Tirmizi",
  "hadith58": "\"Sesiapa yang berselawat ke atasku sekali, Allah akan berselawat ke atasnya sepuluh kali.\"\n— Muslim",
  "hadith65": "\"Orang beriman adalah cermin bagi orang beriman yang lain.\"\n— Abu Dawud",
  "hadith66": "\"Kejujuran membawa kepada kebaikan, dan kebaikan membawa kepada syurga.\"\n— Bukhari & Muslim",
  "hadith67": "\"Kembalikan amanah kepada yang mempercayaimu, dan jangan mengkhianati orang yang mengkhianatimu.\"\n— Abu Dawud & Tirmizi",
  "hadith68": "\"Tiada keletihan, penyakit, kesedihan, kedukaan, kesakitan atau kesusahan yang menimpa seorang Muslim — walaupun tertusuk duri — melainkan Allah menghapuskan sebahagian dosanya.\"\n— Bukhari & Muslim",
  "hadith69": "\"Doa seorang Muslim untuk saudaranya tanpa pengetahuannya sentiasa dimakbulkan.\"\n— Muslim",
  "hadith70": "\"Sesiapa yang memohon syurga kepada Allah tiga kali, syurga berkata: Ya Allah, masukkanlah dia ke syurga.\"\n— Tirmizi",
  "hadith71": "\"Puasa yang paling utama selepas Ramadan ialah puasa pada bulan Allah iaitu Muharram.\"\n— Muslim",
  "hadith72": "\"Sesiapa yang menunaikan haji dan tidak melakukan perbuatan keji mahupun dosa, dia kembali seperti hari ibunya melahirkannya.\"\n— Bukhari & Muslim",
  "hadith73": "\"Umrah ke umrah adalah penghapus dosa di antara keduanya.\"\n— Bukhari & Muslim",
  "hadith74": "\"Bersegeralah melakukan amal kebaikan sebelum datangnya fitnah seperti kepingan malam yang gelap.\"\n— Muslim",
  "hadith75": "\"Dua rakaat Subuh lebih baik daripada dunia dan segala isinya.\"\n— Muslim",
  "hadith77": "\"Jika kamu bertawakal kepada Allah dengan sebenar-benar tawakal, nescaya Allah akan memberi rezeki kepadamu sebagaimana Dia memberi rezeki kepada burung.\"\n— Tirmizi",
  "hadith78": "\"Sesiapa yang menziarahi orang sakit, dia berada dalam taman syurga sehingga dia pulang.\"\n— Muslim",
  "hadith79": "\"Sebarkanlah salam, berilah makan, dan solatlah pada waktu malam ketika orang lain tidur — nescaya kamu masuk syurga dengan selamat.\"\n— Tirmizi",
  "hadith80": "\"Sesiapa yang tidak berterima kasih kepada manusia, tidak berterima kasih kepada Allah.\"\n— Tirmizi",
  "hadith81": "\"Tidak boleh hasad dengki kecuali dalam dua perkara: orang yang dikurniakan Allah harta lalu dia membelanjakannya di jalan yang benar, dan orang yang dikurniakan Allah hikmah lalu dia menghukum dan mengajar dengannya.\"\n— Bukhari & Muslim",
  "hadith82": "\"Seseorang itu mengikut agama sahabat karibnya, maka hendaklah setiap kamu melihat siapa yang dijadikan temannya.\"\n— Abu Dawud & Tirmizi",
  "hadith85": "\"Sesiapa yang meninggalkan sesuatu kerana Allah, Allah akan menggantikannya dengan yang lebih baik.\"\n— Ahmad",
  "hadith86": "\"Sesiapa yang menutup aib seorang Muslim, Allah akan menutup aibnya pada Hari Kiamat.\"\n— Bukhari & Muslim",
  "hadith87": "\"Jadilah di dunia ini seolah-olah kamu seorang asing atau musafir.\"\n— Bukhari",
  "hadith88": "\"Sesiapa yang memudahkan orang yang dalam kesulitan, Allah akan memudahkannya di dunia dan akhirat.\"\n— Muslim",
  "hadith89": "\"Pahala amalan bergantung kepada niat.\"\n— Bukhari & Muslim",
  "hadith90": "\"Jauhilah sangka buruk, kerana sangka buruk adalah seburuk-buruk perkataan.\"\n— Bukhari & Muslim",
  "hadith93": "\"Makanlah bersama-sama dan sebutlah nama Allah, nescaya makanan itu diberkati untuk kamu.\"\n— Abu Dawud",
  "hadith94": "\"Sebaik-baik majlis ialah yang paling luas.\"\n— Abu Dawud",
  "hadith95": "\"Maafkanlah, nescaya kamu akan dimaafkan.\"\n— Ahmad",
  "hadith96": "\"Ikatlah untamu kemudian bertawakallah kepada Allah.\"\n— Tirmizi",
  "hadith97": "\"Sungguh menakjubkan urusan orang beriman — semuanya baik baginya.\"\n— Muslim",
  "hadith98": "\"Seorang Muslim adalah saudara bagi Muslim yang lain: dia tidak menzaliminya, tidak membiarkannya, dan tidak menghinanya.\"\n— Muslim"
}
