  "hadith0": "\"Allah'a en sevimli ameller, az da olsa devamlılığı olanlardır.\"\n— Buhârî ve Müslim",
  "hadith1": "\"Gücü yettiğiniz kadar salih amel işleyin. Çünkü amellerin en hayırlısı az da olsa devamlı olanıdır.\"\n— İbn Mâce",
  "hadith2": "\"İnsanoğlu öldüğünde ameli kesilir; ancak üç şey bundan müstesnadır: sadaka-i câriye, faydalanılan ilim, kendisine dua eden salih evlat.\"\n— Müslim",
  "hadith3": "\"Kim iki serin (sabah ve ikindi) namazını kılarsa cennete girer.\"\n— Buhârî",
  "hadith4": "\"Allah sizin dışınıza ve mallarınıza bakmaz; fakat kalplerinize ve amellerinize bakar.\"\n— Müslim",
  "hadith5": "\"İnsanların en hayırlısı, insanlara en faydalısı olandır.\"\n— Dârekutnî",
  "hadith6": "\"Kolaylaştırınız, zorlaştırmayınız; müjdeleyiniz, nefret ettirmeyiniz.\"\n— Buhârî",
  "hadith7": "\"Kim ilim aramak için bir yola girerse, Allah ona cennetin yolunu kolaylaştırır.\"\n— Müslim",
  "hadith8": "\"Sadaka malı eksiltmez.\"\n— Müslim",
  "hadith9": "\"Kuvvetli mü'min, zayıf mü'minden daha hayırlı ve Allah'a daha sevimlidir. Her ikisinde de hayır vardır.\"\n— Müslim",
  "historyDayCompleted": "{total} üzerinden {completed} tamamlandı",
  "settingsSchedule": "Zamanlama",
  "settingsAppearance": "Görünüm",
  "settingsAboutTagline": "Günlük din yoldaşınız",
  "settingsRolloverSub": "Gün ne zaman sıfırlanır",
  "hadith10": "\"Kim günde yüz defa 'Sübhanallahi ve bihamdihi' derse, denizin köpüğü kadar da olsa günahları bağışlanır.\"\n— Buhari",
  "hadith11": "\"En hayırlı dua Arefe günü yapılan duadır ve benden önceki peygamberlerin ve benim söylediğimiz en hayırlı söz: La ilahe illallah'tır.\"\n— Tirmizi",
  "hadith12": "\"Kim her farz namazdan sonra Ayet el-Kürsi'yi okursa, onu cennete girmekten ancak ölüm alıkoyar.\"\n— Nesai",
  "hadith13": "\"Güzel söz sadakadır.\"\n— Buhari ve Müslim",
  "hadith14": "\"Allah'a ve ahiret gününe iman eden, ya hayır söylesin ya da sussun.\"\n— Buhari ve Müslim",
  "hadith15": "\"Dul ve yoksulun işini gören kimse, Allah yolunda cihad eden gibidir.\"\n— Buhari",
  "hadith16": "\"Kardeşine tebessüm etmen sadakadır.\"\n— Tirmizi",
  "hadith17": "\"Sizin en hayırlınız Kur'an'ı öğrenen ve öğretendir.\"\n— Buhari",
  "hadith18": "\"Hiç kimse kendi elinin emeğinden daha hayırlı bir yemek yememiştir.\"\n— Buhari",
  "hadith19": "\"Allah Refîk'tir (yumuşaktır) ve her işte yumuşaklığı sever.\"\n— Buhari ve Müslim",
  "settingsAbout": "Hakkında",
  "settingsVersion": "Sürüm",
  "settingsDeveloper": "Geliştirici",
  "hadith20": "\"Kim Ramazan'da iman ederek ve sevabını umarak oruç tutarsa, geçmiş günahları bağışlanır.\"\n— Buhârî ve Müslim",
  "hadith21": "\"Namaz dinin direğidir.\"\n— Beyhakî",
  "hadith22": "\"Ezan ile kamet arasında yapılan dua reddedilmez.\"\n— Ebû Dâvûd",
  "hadith23": "\"Kim Allah için bir mescit inşa ederse, Allah da ona cennette bir ev inşa eder.\"\n— Buhârî ve Müslim",
  "hadith24": "\"Erkekler için en hayırlı saf birinci saf, kadınlar için en hayırlı saf ise son saftır.\"\n— Müslim",
  "hadith25": "\"Oruç cehennem ateşinden bir kalkandır.\"\n— Nesâî",
  "hadith26": "\"Kim her gün on iki rekât sünnet namazı kılarsa, ona cennette bir ev inşa edilir.\"\n— Müslim",
  "hadith27": "\"Kur'an'ı güzel okuyan kimse, şerefli ve itaatkâr meleklerle beraberdir.\"\n— Buhârî ve Müslim",
  "hadith28": "\"İlim öğrenmek her Müslüman'a farzdır.\"\n— İbn Mâce",
  "hadith29": "\"Sadakanın en faziletlisi su ikram etmektir.\"\n— Ahmed",
  "hadith30": "\"Kim bir mü'minden dünya sıkıntılarından birini giderirse, Allah da kıyamet gününde onun sıkıntılarından birini giderir.\"\n— Müslim",
  "hadith31": "\"Merhamet edenlere Rahman olan Allah da merhamet eder.\"\n— Ebû Dâvûd ve Tirmizî",
  "hadith32": "\"Hayâ imandandır.\"\n— Buhârî ve Müslim",
  "hadith33": "\"Temizlik imanın yarısıdır.\"\n— Müslim",
  "hadith34": "\"Kim sabrederse, Allah ona sabır verir.\"\n— Buhârî ve Müslim",
  "hadith35": "\"En hayırlı servet, Allah'ı zikreden bir dildir.\"\n— Taberânî",
  "hadith36": "\"Sizden biriniz kendisi için istediğini din kardeşi için de istemedikçe gerçek anlamda iman etmiş olmaz.\"\n— Buhârî ve Müslim",
  "hadith37": "\"Aç olanı doyurun, hasta olanı ziyaret edin ve esirleri serbest bırakın.\"\n— Buhârî",
  "hadith38": "\"Kuvvetli kişi güreşte yenen değil, öfke anında kendine hâkim olandır.\"\n— Buhârî ve Müslim",
  "hadith39": "\"Kim iki çenesi ve iki bacağı arasındakini korursa, ben ona cenneti garanti ederim.\"\n— Buhârî",
  "hadith40": "\"Her namazdan sonra otuz üçer kere 'Sübhânallah', 'Elhamdülillah' ve 'Allahu Ekber' deyin.\"\n— Müslim",
  "hadith41": "\"Zikrin en faziletlisi Lâ ilâhe illallah'tır.\"\n— Tirmizî",
  "hadith42": "\"İnsanların çoğunun aldandığı iki nimet vardır: sağlık ve boş vakit.\"\n— Buhârî",
  "hadith43": "\"Beş şeyi beş şeyden önce değerlendir: gençliğini yaşlılığından önce, sağlığını hastalığından önce, zenginliğini fakirliğinden önce, boş vaktini meşguliyetinden önce ve hayatını ölümünden önce.\"\n— Hâkim",
  "hadith44": "\"Kim İhlâs suresini on kere okursa, Allah ona cennette bir ev inşa eder.\"\n— Ahmed",
  "hadith45": "\"Farz namazlardan sonra en faziletli namaz gece namazıdır.\"\n— Müslim",
  "hadith46": "\"Sadaka, suyun ateşi söndürdüğü gibi günahları söndürür.\"\n— Tirmizî",
  "hadith47": "\"Sıla-i rahim yapan, karşılık gören değildir. Asıl sıla-i rahim yapan, akrabası ilişkiyi kestiğinde bile devam edendir.\"\n— Buhârî",
  "hadith48": "\"Her iyilik sadakadır.\"\n— Buhârî ve Müslim",
  "hadith49": "\"Kim yiyip de 'Elhamdülillah' derse, geçmiş günahları bağışlanır.\"\n— Tirmizî",
  "hadith50": "\"Allah'a en sevimli insanlar, başkalarına en faydalı olanlardır.\"\n— Taberânî",
  "hadith51": "\"Gücü yettiği hâlde öfkesini yutan kimseyi Allah, kıyamet gününde bütün mahlûkatın huzurunda çağırır ve dilediği huriyi seçmesini söyler.\"\n— Tirmizî",
  "hadith52": "\"Sadakayı geciktirmeden verin, çünkü o belanın önünde durur.\"\n— Tirmizî",
  "hadith53": "\"Hiçbir iyiliği küçümseme; din kardeşini güler yüzle karşılaman bile olsa.\"\n— Müslim",
  "hadith54": "\"Sizin en hayırlınız, ailesine karşı en iyi olanınızdır.\"\n— Tirmizî",
  "hadith55": "\"Kim gece Bakara suresinin son iki ayetini okursa, ona yeter.\"\n— Buhârî ve Müslim",
  "hadith56": "\"Dünya bir geçimlik metadır; en hayırlı meta ise saliha bir kadındır.\"\n— Müslim",
  "hadith57": "\"Üç dua reddedilmez: oruçlunun duası, âdil yöneticinin duası ve mazlumun duası.\"\n— Tirmizî",
  "hadith58": "\"Kim bana bir kere salât getirirse, Allah ona on kere salât eder.\"\n— Müslim",
  "hadith59": "\"Mescid, her takva sahibinin evidir.\"\n— Taberânî",
  "hadith60": "\"Kim 'Lâ havle ve lâ kuvvete illâ billâh' derse, bu doksan dokuz derde devadır; en hafifi üzüntüdür.\"\n— Hâkim",
  "hadith61": "\"Allah, herhangi biriniz bir iş yaptığında onu güzel yapmasını sever.\"\n— Taberânî",
  "hadith62": "\"Cennet annelerin ayakları altındadır.\"\n— Nesâî",
  "hadith63": "\"Anne babaya iyilik, en büyük farz ameldir.\"\n— Buhârî",
  "hadith64": "\"Aza şükredenin çoğu verilir.\"\n— Beyhakî",
  "hadith65": "\"Mü'min mü'minin aynasıdır.\"\n— Ebû Dâvûd",
  "hadith66": "\"Doğruluk iyiliğe, iyilik de cennete götürür.\"\n— Buhârî ve Müslim",
  "hadith67": "\"Emaneti sana bırakana emanetini ver; sana ihanet edene ihanet etme.\"\n— Ebû Dâvûd ve Tirmizî",
  "hadith68": "\"Müslüman'a isabet eden yorgunluk, hastalık, üzüntü, keder, sıkıntı ve gamdan — hatta ayağına batan dikenden bile — Allah mutlaka günahlarından bir kısmını bağışlar.\"\n— Buhârî ve Müslim",
  "hadith69": "\"Müslüman'ın gıyabında kardeşi için yaptığı dua kabul olunur.\"\n— Müslim",
  "hadith70": "\"Kim Allah'tan üç kere cennet isterse, cennet 'Allah'ım, onu cennete koy' der.\"\n— Tirmizî",
  "hadith71": "\"Ramazan'dan sonra en faziletli oruç, Allah'ın ayı olan Muharrem'de tutulan oruçtur.\"\n— Müslim",
  "hadith72": "\"Kim hac yapar da kötü söz söylemez ve günah işlemezse, annesinin onu doğurduğu günkü gibi döner.\"\n— Buhârî ve Müslim",
  "hadith73": "\"Bir umre, diğer umreye kadar olan günahlara kefarettir.\"\n— Buhârî ve Müslim",
  "hadith74": "\"Hayırlı işlere koşun.\"\n— Müslim",
  "hadith75": "\"Sabah namazının iki rekât sünneti, dünya ve içindeki her şeyden daha hayırlıdır.\"\n— Müslim",
  "hadith76": "\"Kim sürekli istiğfar ederse, Allah her darlıktan bir çıkış yolu yaratır.\"\n— Ebû Dâvûd",
  "hadith77": "\"Allah'a hakkıyla tevekkül etseydiniz, kuşları rızıklandırdığı gibi sizi de rızıklandırırdı.\"\n— Tirmizî",
  "hadith78": "\"Hastayı ziyaret eden kimse, dönünceye kadar cennet bahçesindedir.\"\n— Müslim",
  "hadith79": "\"Selâmı yayın, yemek yedirin, insanlar uyurken gece namazı kılın; selâmetle cennete girersiniz.\"\n— Tirmizî",
  "hadith80": "\"Allah'ın en çok sevdiği ameller, az da olsa devamlı olanlardır.\"\n— Buhârî",
  "hadith81": "\"Gıpta ancak iki kişiye yapılır: Allah'ın mal verip hak yolda harcatan kişiye ve Allah'ın hikmet verip onunla hükmeden ve onu öğreten kişiye.\"\n— Buhârî ve Müslim",
  "hadith82": "\"Kişi dostunun dini üzeredir. Bu yüzden her biriniz kiminle arkadaşlık ettiğine dikkat etsin.\"\n— Ebû Dâvûd ve Tirmizî",
  "hadith83": "\"Ölümü çokça hatırlayın; çünkü o kalbi arındırır.\"\n— Tirmizî",
  "hadith84": "\"Sizin en hayırlınız, kalbi en yumuşak olanınızdır.\"\n— Taberânî",
  "hadith85": "\"Allah hiçbir nefse taşıyamayacağı yükü yüklemez.\"\n— Kur'ân 2:286",
  "hadith86": "\"Kim bir Müslüman'ın ayıbını örterse, Allah da kıyamet gününde onun ayıbını örter.\"\n— Buhârî ve Müslim",
  "hadith87": "\"Dünyada bir garip ya da bir yolcu gibi ol.\"\n— Buhârî",
  "hadith88": "\"Kim zor durumda olana kolaylık gösterirse, Allah da dünya ve ahirette ona kolaylık gösterir.\"\n— Müslim",
  "hadith89": "\"Ameller niyetlere göredir.\"\n— Buhârî ve Müslim",
  "hadith90": "\"Zandan sakının; çünkü zan sözün en yalanıdır.\"\n— Buhârî ve Müslim",
  "hadith91": "\"Kim şaka bile olsa yalanı terk ederse, ona cennetin kenarında bir köşk garanti ederim.\"\n— Ebû Dâvûd",
  "hadith92": "\"Hayır kapıları çoktur: Allah'ı tesbih etmek, O'na hamd etmek, sadaka vermek, iyiliği emretmek ve yoldan zararlıyı kaldırmak.\"\n— Müslim",
  "hadith93": "\"Birlikte yiyin ve besmele çekin; yemeğiniz bereketlenir.\"\n— Ebû Dâvûd",
  "hadith94": "\"Meclislerin en hayırlısı en geniş olanıdır.\"\n— Ebû Dâvûd",
  "hadith95": "\"Affet ki affolunasin.\"\n— Ahmed",
  "hadith96": "\"Deveni bağla, sonra Allah'a tevekkül et.\"\n— Tirmizî",
  "hadith97": "\"Mü'minin hâli ne hoştur; her hâli onun için hayırdır.\"\n— Müslim",
  "hadith98": "\"Müslüman Müslüman'ın kardeşidir: ona zulmetmez, onu yalnız bırakmaz, onu küçümsemez.\"\n— Müslim",
  "hadith99": "\"Allah'a en sevimli söz 'Sübhânallahi ve bihamdihî, Sübhânallahi'l-Azîm'dir.\"\n— Buhârî ve Müslim"
}
