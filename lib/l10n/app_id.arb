  "hadith0": "\"Amalan yang paling dicintai Allah adalah yang dilakukan secara konsisten, meskipun sedikit.\"\n— Bukhari & Muslim",
  "hadith1": "\"Lakukanlah amalan kebaikan sesuai kemampuanmu, karena amalan terbaik adalah yang dilakukan secara konsisten meskipun sedikit.\"\n— Ibnu Majah",
  "hadith2": "\"Apabila anak Adam meninggal dunia, terputuslah amalnya kecuali tiga perkara: sedekah jariyah, ilmu yang bermanfaat, atau anak saleh yang mendoakannya.\"\n— Muslim",
  "hadith3": "\"Barangsiapa yang menjaga dua shalat dingin (Subuh dan Ashar), maka ia akan masuk surga.\"\n— Bukhari",
  "hadith4": "\"Sesungguhnya Allah tidak melihat rupa dan hartamu, tetapi Dia melihat hati dan amalmu.\"\n— Muslim",
  "hadith5": "\"Sebaik-baik manusia adalah yang paling bermanfaat bagi manusia.\"\n— Daraquthni",
  "hadith6": "\"Mudahkanlah dan jangan mempersulit; berilah kabar gembira dan jangan membuat orang lari.\"\n— Bukhari",
  "hadith7": "\"Barangsiapa menempuh jalan untuk menuntut ilmu, Allah akan memudahkan baginya jalan menuju surga.\"\n— Muslim",
  "hadith8": "\"Sedekah tidak mengurangi harta.\"\n— Muslim",
  "hadith9": "\"Mukmin yang kuat lebih baik dan lebih dicintai Allah daripada mukmin yang lemah, dan pada keduanya ada kebaikan.\"\n— Muslim",
  "historyDayCompleted": "{completed} dari {total} selesai",
  "settingsSchedule": "Jadwal",
  "settingsAppearance": "Tampilan",
  "settingsAboutTagline": "Pendamping deen harian Anda",
  "settingsRolloverSub": "Kapan hari direset",
  "hadith10": "\"Barangsiapa membaca 'SubhanAllah wa bihamdihi' seratus kali dalam sehari, dosanya akan diampuni meski seperti buih di lautan.\"\n— Bukhari",
  "hadith11": "\"Doa terbaik adalah doa pada hari Arafah, dan sebaik-baik yang diucapkan olehku dan para nabi sebelumku adalah: La ilaha illallah.\"\n— Tirmidzi",
  "hadith12": "\"Barangsiapa membaca Ayat Kursi setelah setiap shalat wajib, tidak ada yang menghalanginya masuk surga kecuali kematian.\"\n— Nasa'i",
  "hadith13": "\"Perkataan yang baik adalah sedekah.\"\n— Bukhari & Muslim",
  "hadith14": "\"Barangsiapa beriman kepada Allah dan hari akhir, hendaklah berkata baik atau diam.\"\n— Bukhari & Muslim",
  "hadith15": "\"Orang yang menanggung janda dan orang miskin seperti pejuang di jalan Allah.\"\n— Bukhari",
  "hadith16": "\"Tersenyum kepada saudaramu adalah sedekah.\"\n— Tirmidzi",
  "hadith17": "\"Sebaik-baik kalian adalah yang mempelajari Al-Quran dan mengajarkannya.\"\n— Bukhari",
  "hadith18": "\"Tidak ada makanan yang lebih baik dari hasil kerja tangannya sendiri.\"\n— Bukhari",
  "hadith19": "\"Allah itu lembut dan mencintai kelembutan dalam segala hal.\"\n— Bukhari & Muslim",
  "settingsAbout": "Tentang",
  "settingsVersion": "Versi",
  "settingsDeveloper": "Pengembang",
  "hadith20": "\"Barangsiapa berpuasa Ramadan karena iman dan mengharap pahala, diampunilah dosa-dosanya yang telah lalu.\"\n— Bukhari & Muslim",
  "hadith21": "\"Shalat adalah tiang agama.\"\n— Baihaqi",
  "hadith22": "\"Doa antara adzan dan iqamah tidak ditolak.\"\n— Abu Dawud",
  "hadith23": "\"Barangsiapa membangun masjid karena Allah, Allah akan membangunkan untuknya rumah di surga.\"\n— Bukhari & Muslim",
  "hadith24": "\"Sebaik-baik shaf laki-laki adalah yang pertama, dan sebaik-baik shaf perempuan adalah yang terakhir.\"\n— Muslim",
  "hadith25": "\"Puasa adalah perisai dari api neraka.\"\n— Nasa'i",
  "hadith26": "\"Barangsiapa shalat dua belas rakaat sunnah, dibangunkan untuknya rumah di surga.\"\n— Muslim",
  "hadith27": "\"Orang yang mahir membaca Al-Quran bersama para malaikat yang mulia.\"\n— Bukhari & Muslim",
  "hadith28": "\"Menuntut ilmu wajib bagi setiap Muslim.\"\n— Ibnu Majah",
  "hadith29": "\"Sebaik-baik sedekah adalah memberi minum air.\"\n— Ahmad",
  "hadith30": "\"Barangsiapa membaca Surah Al-Kahfi pada hari Jumat, akan disinari cahaya antara dua Jumat.\"\n— Hakim",
  "hadith31": "\"Bertakwalah kepada Allah di mana pun kamu berada, dan ikutilah keburukan dengan kebaikan, niscaya ia akan menghapusnya.\"\n— Tirmidzi",
  "hadith32": "\"Mudahkanlah dan jangan mempersulit; berilah kabar gembira dan jangan membuat orang menjauh.\"\n— Bukhari",
  "hadith33": "\"Kebersihan adalah sebagian dari iman.\"\n— Muslim",
  "hadith34": "\"Manusia yang paling dicintai Allah adalah yang paling bermanfaat bagi manusia.\"\n— Thabarani",
  "hadith35": "\"Sedekah tidak mengurangi harta.\"\n— Muslim",
  "hadith36": "\"Sebaik-baik kalian adalah yang belajar Al-Quran dan mengajarkannya.\"\n— Bukhari",
  "hadith37": "\"Barangsiapa menempuh jalan untuk mencari ilmu, Allah mudahkan baginya jalan menuju surga.\"\n— Muslim",
  "hadith38": "\"Tidak beriman salah seorang di antara kalian hingga ia mencintai saudaranya seperti mencintai dirinya sendiri.\"\n— Bukhari & Muslim",
  "hadith39": "\"Perbuatan baik melindungi dari keburukan.\"\n— Thabarani",
  "hadith40": "\"Barangsiapa mengucapkan 'Subhanallahi wa bihamdihi,' ditanam untuknya pohon kurma di surga.\"\n— Tirmidzi",
  "hadith41": "\"Sesungguhnya setiap amalan tergantung pada niatnya.\"\n— Bukhari & Muslim",
  "hadith42": "\"Barangsiapa shalat Subuh berjamaah, ia dalam perlindungan Allah.\"\n— Muslim",
  "hadith43": "\"Seorang hamba paling dekat dengan Tuhannya saat bersujud, maka perbanyaklah doa.\"\n— Muslim",
  "hadith44": "\"Kesabaran adalah cahaya.\"\n— Muslim",
  "hadith45": "\"Tidak bersyukur kepada Allah orang yang tidak berterima kasih kepada manusia.\"\n— Abu Dawud",
  "hadith46": "\"Tidaklah seorang Muslim menanam tanaman lalu dimakan manusia atau burung, melainkan itu menjadi sedekah baginya.\"\n— Bukhari",
  "hadith47": "\"Sebaik-baik kalian adalah yang terbaik terhadap keluarganya.\"\n— Tirmidzi",
  "hadith48": "\"Barangsiapa menahan amarah padahal mampu melampiaskannya, Allah akan memanggilnya di hadapan seluruh makhluk pada hari kiamat.\"\n— Abu Dawud",
  "hadith49": "\"Senyummu di hadapan saudaramu adalah sedekah.\"\n— Tirmidzi",
  "hadith50": "\"Orang yang paling dicintai Allah adalah yang paling bermanfaat bagi orang lain.\"\n— Thabrani",
  "hadith51": "\"Barangsiapa menahan amarahnya padahal ia mampu melampiaskannya, Allah akan memanggilnya di hadapan seluruh makhluk pada Hari Kiamat untuk memilih pahalanya.\"\n— Tirmidzi",
  "hadith52": "\"Bersegeralah bersedekah, karena sedekah menghalangi datangnya musibah.\"\n— Tirmidzi",
  "hadith53": "\"Jangan meremehkan kebaikan sekecil apapun, meskipun hanya bertemu saudaramu dengan wajah berseri.\"\n— Muslim",
  "hadith54": "\"Sebaik-baik kalian adalah yang terbaik terhadap keluarganya.\"\n— Tirmidzi",
  "hadith55": "\"Barangsiapa membaca dua ayat terakhir Surah Al-Baqarah pada malam hari, maka itu cukup baginya.\"\n— Bukhari & Muslim",
  "hadith56": "\"Dunia adalah perhiasan, dan sebaik-baik perhiasan adalah istri yang shalihah.\"\n— Muslim",
  "hadith57": "\"Tiga doa yang tidak ditolak: doa orang yang berpuasa, pemimpin yang adil, dan orang yang teraniaya.\"\n— Tirmidzi",
  "hadith58": "\"Barangsiapa bershalawat kepadaku sekali, Allah akan bershalawat kepadanya sepuluh kali.\"\n— Muslim",
  "hadith59": "\"Masjid adalah rumah setiap orang bertakwa.\"\n— Thabrani",
  "hadith60": "\"Barangsiapa mengucapkan 'La hawla wa la quwwata illa billah' — itu adalah obat bagi sembilan puluh sembilan penyakit, yang paling ringannya adalah kegelisahan.\"\n— Hakim",
  "hadith61": "\"Allah mencintai jika seseorang melakukan sesuatu, ia melakukannya dengan sebaik-baiknya.\"\n— Thabrani",
  "hadith62": "\"Surga berada di bawah telapak kaki ibu.\"\n— Nasa'i",
  "hadith63": "\"Berbakti kepada orang tua adalah kewajiban yang paling agung.\"\n— Bukhari",
  "hadith64": "\"Barangsiapa bersyukur atas yang sedikit, akan diberi yang banyak.\"\n— Baihaqi",
  "hadith65": "\"Mukmin adalah cermin bagi mukmin lainnya.\"\n— Abu Dawud",
  "hadith66": "\"Kejujuran membawa kepada kebaikan, dan kebaikan membawa kepada surga.\"\n— Bukhari & Muslim",
  "hadith67": "\"Kembalikanlah amanah kepada yang mempercayaimu, dan jangan berkhianat kepada yang mengkhianatimu.\"\n— Abu Dawud & Tirmidzi",
  "hadith68": "\"Tidaklah seorang Muslim tertimpa kelelahan, penyakit, kesedihan, kesusahan, gangguan, atau kegelisahan, bahkan tertusuk duri sekalipun, melainkan Allah menghapus sebagian dosanya karenanya.\"\n— Bukhari & Muslim",
  "hadith69": "\"Doa seorang Muslim untuk saudaranya yang tidak hadir selalu dikabulkan.\"\n— Muslim",
  "hadith70": "\"Barangsiapa meminta surga kepada Allah tiga kali, surga berkata: Ya Allah, masukkanlah ia ke surga.\"\n— Tirmidzi",
  "hadith71": "\"Puasa yang paling utama setelah Ramadan adalah puasa di bulan Allah, Muharram.\"\n— Muslim",
  "hadith72": "\"Barangsiapa menunaikan haji dan tidak berkata-kata kotor serta tidak berbuat fasik, maka ia kembali seperti hari ia dilahirkan ibunya.\"\n— Bukhari & Muslim",
  "hadith73": "\"Umrah ke umrah adalah penghapus dosa di antara keduanya.\"\n— Bukhari & Muslim",
  "hadith74": "\"Berlomba-lombalah dalam kebaikan.\"\n— Muslim",
  "hadith75": "\"Dua rakaat Fajar lebih baik dari dunia dan segala isinya.\"\n— Muslim",
  "hadith76": "\"Barang siapa yang istiqamah beristighfar, Allah akan memberikan jalan keluar dari setiap kesulitan.\"\n— Abu Dawud",
  "hadith77": "\"Seandainya kalian bertawakal kepada Allah dengan sebenar-benarnya, niscaya Dia akan memberi kalian rezeki sebagaimana Dia memberi rezeki kepada burung.\"\n— Tirmidzi",
  "hadith78": "\"Barang siapa yang menjenguk orang sakit, ia berada di taman surga hingga ia kembali.\"\n— Muslim",
  "hadith79": "\"Sebarkanlah salam, berilah makan, dan salatlah di malam hari saat orang-orang tidur — kalian akan masuk surga dengan damai.\"\n— Tirmidzi",
  "hadith80": "\"Amal yang paling dicintai Allah adalah yang paling konsisten, meskipun sedikit.\"\n— Bukhari",
  "hadith81": "\"Tidak boleh iri kecuali dalam dua hal: seseorang yang diberi harta oleh Allah lalu ia menghabiskannya di jalan kebenaran, dan seseorang yang diberi hikmah lalu ia memutuskan dan mengajarkannya.\"\n— Bukhari & Muslim",
  "hadith82": "\"Seseorang itu mengikuti agama temannya, maka hendaklah salah seorang dari kalian melihat siapa yang ia jadikan teman.\"\n— Abu Dawud & Tirmidzi",
  "hadith83": "\"Perbanyaklah mengingat kematian, karena ia membersihkan hati.\"\n— Tirmidzi",
  "hadith84": "\"Sebaik-baik kalian adalah yang paling lembut hatinya.\"\n— Thabrani",
  "hadith85": "\"Allah tidak membebani seseorang melainkan sesuai dengan kemampuannya.\"\n— Al-Quran 2:286",
  "hadith86": "\"Barang siapa yang menutupi aib seorang muslim, Allah akan menutupi aibnya pada Hari Kiamat.\"\n— Bukhari & Muslim",
  "hadith87": "\"Jadilah di dunia ini seakan-akan engkau orang asing atau musafir.\"\n— Bukhari",
  "hadith88": "\"Barang siapa yang memudahkan orang yang dalam kesulitan, Allah akan memudahkannya di dunia dan akhirat.\"\n— Muslim",
  "hadith89": "\"Sesungguhnya setiap amal tergantung pada niatnya.\"\n— Bukhari & Muslim",
  "hadith90": "\"Jauhilah prasangka, karena prasangka adalah ucapan yang paling dusta.\"\n— Bukhari & Muslim",
  "hadith91": "\"Barang siapa yang meninggalkan dusta demi Allah, meskipun dalam bercanda, aku menjamin baginya sebuah istana di pinggiran surga.\"\n— Abu Dawud",
  "hadith92": "\"Pintu-pintu kebaikan itu banyak: bertasbih, memuji Allah, bersedekah, menyuruh kebaikan, dan menyingkirkan gangguan dari jalan.\"\n— Muslim",
  "hadith93": "\"Makanlah bersama-sama dan sebutlah nama Allah, niscaya akan diberkahi untuk kalian.\"\n— Abu Dawud",
  "hadith94": "\"Sebaik-baik majelis adalah yang paling lapang.\"\n— Abu Dawud",
  "hadith95": "\"Maafkanlah, niscaya kalian akan dimaafkan.\"\n— Ahmad",
  "hadith96": "\"Ikatlah untamu, kemudian bertawakallah kepada Allah.\"\n— Tirmidzi",
  "hadith97": "\"Sungguh menakjubkan urusan orang beriman — segala sesuatunya baik baginya.\"\n— Muslim",
  "hadith98": "\"Seorang muslim adalah saudara bagi muslim lainnya: ia tidak menzaliminya, tidak meninggalkannya, dan tidak menghinakannya.\"\n— Muslim",
  "hadith99": "\"Ucapan yang paling dicintai Allah adalah: SubhanAllahi wa bihamdihi, SubhanAllahil Azhim.\"\n— Bukhari & Muslim"
}
