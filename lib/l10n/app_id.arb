  "sundayFull": "Minggu",
  "hadith0": "\"Amalan yang paling dicintai Allah adalah yang dilakukan secara konsisten, meskipun sedikit.\"\n— Bukhari & Muslim",
  "hadith1": "\"Lakukanlah amalan kebaikan sesuai kemampuanmu, karena amalan terbaik adalah yang dilakukan secara konsisten meskipun sedikit.\"\n— Ibnu Majah",
  "hadith2": "\"Apabila anak Adam meninggal dunia, terputuslah amalnya kecuali tiga perkara: sedekah jariyah, ilmu yang bermanfaat, atau anak saleh yang mendoakannya.\"\n— Muslim",
  "hadith3": "\"Barangsiapa yang menjaga dua shalat dingin (Subuh dan Ashar), maka ia akan masuk surga.\"\n— Bukhari",
  "hadith4": "\"Sesungguhnya Allah tidak melihat rupa dan hartamu, tetapi Dia melihat hati dan amalmu.\"\n— Muslim",
  "hadith5": "\"Sebaik-baik manusia adalah yang paling bermanfaat bagi manusia.\"\n— Daraquthni",
  "hadith6": "\"Mudahkanlah dan jangan mempersulit; berilah kabar gembira dan jangan membuat orang lari.\"\n— Bukhari",
  "hadith7": "\"Barangsiapa menempuh jalan untuk menuntut ilmu, Allah akan memudahkan baginya jalan menuju surga.\"\n— Muslim",
  "hadith8": "\"Sedekah tidak mengurangi harta.\"\n— Muslim",
  "hadith9": "\"Mukmin yang kuat lebih baik dan lebih dicintai Allah daripada mukmin yang lemah, dan pada keduanya ada kebaikan.\"\n— Muslim",
  "historyDayCompleted": "{completed} dari {total} selesai",
  "settingsSchedule": "Jadwal",
  "settingsAppearance": "Tampilan",
  "settingsAboutTagline": "Pendamping deen harian Anda",
  "settingsRolloverSub": "Kapan hari direset",
  "hadith10": "\"Barangsiapa membaca 'SubhanAllah wa bihamdihi' seratus kali dalam sehari, dosanya akan diampuni meski seperti buih di lautan.\"\n— Bukhari",
  "hadith11": "\"Doa terbaik adalah doa pada hari Arafah, dan sebaik-baik yang diucapkan olehku dan para nabi sebelumku adalah: La ilaha illallah.\"\n— Tirmidzi",
  "hadith12": "\"Barangsiapa membaca Ayat Kursi setelah setiap shalat wajib, tidak ada yang menghalanginya masuk surga kecuali kematian.\"\n— Nasa'i",
  "hadith13": "\"Perkataan yang baik adalah sedekah.\"\n— Bukhari & Muslim",
  "hadith14": "\"Barangsiapa beriman kepada Allah dan hari akhir, hendaklah berkata baik atau diam.\"\n— Bukhari & Muslim",
  "hadith15": "\"Orang yang menanggung janda dan orang miskin seperti pejuang di jalan Allah.\"\n— Bukhari",
  "hadith16": "\"Tersenyum kepada saudaramu adalah sedekah.\"\n— Tirmidzi",
  "hadith17": "\"Sebaik-baik kalian adalah yang mempelajari Al-Quran dan mengajarkannya.\"\n— Bukhari",
  "hadith18": "\"Tidak ada makanan yang lebih baik dari hasil kerja tangannya sendiri.\"\n— Bukhari",
  "hadith19": "\"Allah itu lembut dan mencintai kelembutan dalam segala hal.\"\n— Bukhari & Muslim"
}
