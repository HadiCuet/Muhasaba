  "hadith0": "«محبوب‌ترین اعمال نزد خداوند آن‌هایی هستند که مداومت داشته باشند، هرچند اندک باشند.»\n— بخاری و مسلم",
  "hadith2": "«چون فرزند آدم بمیرد، عملش قطع می‌شود مگر از سه چیز: صدقه جاریه، علم سودمند، یا فرزند صالحی که برایش دعا کند.»\n— مسلم",
  "hadith3": "«هرکس دو نماز خنک (فجر و عصر) را بخواند، وارد بهشت می‌شود.»\n— بخاری",
  "hadith4": "«خداوند به ظاهر و ثروت شما نمی‌نگرد، بلکه به دل‌ها و اعمال شما می‌نگرد.»\n— مسلم",
  "hadith6": "«آسان بگیرید و سخت نگیرید؛ مژده دهید و مردم را نرمانید.»\n— بخاری",
  "hadith7": "«هرکس راهی را برای جستجوی علم بپیماید، خداوند راه بهشت را برایش آسان می‌سازد.»\n— مسلم",
  "hadith8": "«صدقه مال را کم نمی‌کند.»\n— مسلم",
  "hadith9": "«مؤمن قوی بهتر و محبوب‌تر نزد خداوند است از مؤمن ضعیف، و در هر دو خیر هست.»\n— مسلم",
  "historyDayCompleted": "{completed} از {total} انجام شده",
  "settingsSchedule": "زمان‌بندی",
  "settingsAppearance": "ظاهر",
  "settingsAboutTagline": "همراه روزانه دین شما",
  "settingsRolloverSub": "روز چه زمانی بازنشانی می‌شود",
  "hadith10": "«هر کس روزی صد بار 'سبحان‌الله و بحمده' بگوید، گناهانش آمرزیده می‌شود حتی اگر مانند کف دریا باشد.»\n— بخاری",
  "hadith12": "«هر کس پس از هر نماز واجب آیة‌الکرسی بخواند، چیزی مانع ورود او به بهشت نمی‌شود مگر مرگ.»\n— نسائی",
  "hadith13": "«سخن نیک صدقه است.»\n— بخاری و مسلم",
  "hadith14": "«هر کس به خدا و روز قیامت ایمان دارد، سخن نیک بگوید یا سکوت کند.»\n— بخاری و مسلم",
  "hadith15": "«کسی که از بیوه‌زن و مسکین مراقبت کند، مانند مجاهد در راه خداست.»\n— بخاری",
  "hadith16": "«لبخند زدن به برادرت صدقه است.»\n— ترمذی",
  "hadith17": "«بهترین شما کسی است که قرآن بیاموزد و آن را بیاموزاند.»\n— بخاری",
  "hadith18": "«هیچ‌کس غذایی بهتر از دسترنج خود نخورده است.»\n— بخاری",
  "hadith19": "«خداوند مهربان است و در همه امور مهربانی را دوست دارد.»\n— بخاری و مسلم",
  "settingsAbout": "درباره",
  "settingsVersion": "نسخه",
  "settingsDeveloper": "توسعه‌دهنده",
  "settingsSupport": "پشتیبانی",
  "settingsRate": "به برنامه امتیاز دهید",
  "settingsContact": "تماس با ما",
  "settingsReportBug": "گزارش اشکال",
  "settingsRequestFeature": "درخواست ویژگی",
  "settingsSupportFallback": "نمی‌توان ایمیل را باز کرد. لطفاً به {email} ایمیل بزنید.",
  "hadith20": "«هر کس ماه رمضان را با ایمان و به امید ثواب روزه بدارد، گناهان گذشته‌اش آمرزیده می‌شود.»\n— بخاری و مسلم",
  "hadith22": "«دعای بین اذان و اقامه رد نمی‌شود.»\n— ابوداوود",
  "hadith23": "«هر کس مسجدی برای خدا بسازد، خداوند برایش خانه‌ای در بهشت می‌سازد.»\n— بخاری و مسلم",
  "hadith24": "«بهترین صف‌ها برای مردان صف اول و بهترین صف‌ها برای زنان صف آخر است.»\n— مسلم",
  "hadith25": "«روزه سپری در برابر آتش جهنم است.»\n— نسائی",
  "hadith26": "«هر کس دوازده رکعت نماز سنت بخواند، خانه‌ای در بهشت برایش ساخته می‌شود.»\n— مسلم",
  "hadith27": "«کسی که در خواندن قرآن ماهر باشد، با فرشتگان بزرگوار و نیکوکار همنشین است.»\n— بخاری و مسلم",
  "hadith29": "«بهترین صدقه آب دادن است.»\n— احمد",
  "hadith30": "«هر کس سختی‌ای را از مؤمنی برطرف کند، خداوند سختی‌ای را از او در روز قیامت برطرف می‌کند.»\n— مسلم",
  "hadith32": "«حیا از ایمان است.»\n— بخاری و مسلم",
  "hadith34": "«هر کس صبر کند، خداوند به او صبر عطا می‌کند.»\n— بخاری و مسلم",
  "hadith36": "«هیچ‌یک از شما ایمان کامل ندارد مگر آنکه برای برادرش همان را بخواهد که برای خودش می‌خواهد.»\n— بخاری و مسلم",
  "hadith37": "«گرسنگان را سیر کنید، بیماران را عیادت کنید و اسیران را آزاد کنید.»\n— بخاری",
  "hadith38": "«قوی آن نیست که در کشتی غالب شود، بلکه قوی کسی است که هنگام خشم خود را کنترل کند.»\n— بخاری و مسلم",
  "hadith40": "«پس از هر نماز سی و سه بار 'سبحان‌الله'، 'الحمدلله' و 'الله اکبر' بگویید.»\n— مسلم",
  "hadith41": "«بهترین ذکر لا اله الا الله است.»\n— ترمذی",
  "hadith42": "«دو نعمت است که بسیاری از مردم در آن مغبون هستند: سلامتی و فراغت.»\n— بخاری",
  "hadith43": "«پنج چیز را پیش از پنج چیز غنیمت شمار: جوانی‌ات را پیش از پیری، سلامتی‌ات را پیش از بیماری، ثروتت را پیش از فقر، فراغتت را پیش از مشغولیت، و زندگی‌ات را پیش از مرگ.»\n— حاکم",
  "hadith44": "«هر کس سوره اخلاص را ده بار بخواند، خداوند برایش خانه‌ای در بهشت بنا می‌کند.»\n— احمد",
  "hadith45": "«بهترین نماز پس از نمازهای واجب، نماز شب است.»\n— مسلم",
  "hadith46": "«صدقه گناهان را خاموش می‌کند همان‌طور که آب آتش را خاموش می‌کند.»\n— ترمذی",
  "hadith47": "«صله رحم‌کننده واقعی کسی نیست که مقابله‌به‌مثل کند، بلکه کسی است که حتی وقتی قطع رحم می‌شود، پیوند را حفظ کند.»\n— بخاری",
  "hadith49": "«هر کس غذا بخورد و بگوید: 'سپاس خدایی را که این غذا را به من خوراند و بدون هیچ نیرو و توانی از جانب من آن را روزی‌ام کرد،' گناهان گذشته‌اش آمرزیده می‌شود.»\n— ترمذی",
  "hadith53": "«هیچ کار نیکی را کوچک نشمارید، حتی اگر ملاقات برادرتان با چهره‌ای خندان باشد.»\n— مسلم",
  "hadith54": "«بهترین شما کسی است که با خانواده‌اش بهترین رفتار را داشته باشد.»\n— ترمذی",
  "hadith55": "«هر کس شب دو آیه آخر سوره بقره را بخواند، برایش کافی است.»\n— بخاری و مسلم",
  "hadith56": "«دنیا متاعی است و بهترین متاع آن همسر صالح است.»\n— مسلم",
  "hadith57": "«سه دعا رد نمی‌شود: دعای روزه‌دار، دعای حاکم عادل و دعای مظلوم.»\n— ترمذی",
  "hadith58": "«هر کس بر من یک بار صلوات بفرستد، خداوند ده بار بر او صلوات می‌فرستد.»\n— مسلم",
  "hadith65": "«مؤمن آینه مؤمن است.»\n— ابوداوود",
  "hadith66": "«راستگویی به نیکی می‌رساند و نیکی به بهشت می‌رساند.»\n— بخاری و مسلم",
  "hadith67": "«امانت را به صاحبش برگردان و به کسی که به تو خیانت کرده خیانت نکن.»\n— ابوداوود و ترمذی",
  "hadith68": "«هیچ خستگی، بیماری، اندوه، غم، آزار یا ناراحتی به مسلمان نمی‌رسد — حتی خار خلیدن — مگر آنکه خداوند به واسطه آن گناهانش را می‌بخشد.»\n— بخاری و مسلم",
  "hadith69": "«دعای مسلمان برای برادرش در غیابش همواره مستجاب است.»\n— مسلم",
  "hadith70": "«هر کس سه بار از خداوند بهشت بخواهد، بهشت می‌گوید: خدایا او را وارد بهشت کن.»\n— ترمذی",
  "hadith71": "«فاضل‌ترین روزه پس از رمضان، روزه ماه خدا یعنی محرم است.»\n— مسلم",
  "hadith72": "«هر کس حج کند و مرتکب فحش و گناه نشود، مانند روزی که مادرش او را زاییده بازمی‌گردد.»\n— بخاری و مسلم",
  "hadith73": "«عمره تا عمره کفاره گناهان بین آن دو است.»\n— بخاری و مسلم",
  "hadith74": "«پیش از آنکه فتنه‌ها مانند تکه‌های شب تاریک فرا رسند، به سوی کارهای نیک بشتابید.»\n— مسلم",
  "hadith75": "«دو رکعت سنت فجر از دنیا و آنچه در آن است بهتر است.»\n— مسلم",
  "hadith77": "«اگر بر خداوند آن‌گونه که شایسته اوست توکل می‌کردید، شما را همان‌طور روزی می‌داد که پرندگان را روزی می‌دهد.»\n— ترمذی",
  "hadith78": "«هر کس بیماری را عیادت کند، تا بازگردد در باغ بهشت است.»\n— مسلم",
  "hadith79": "«سلام را بگسترانید، گرسنگان را غذا دهید و شب هنگامی که مردم خوابند نماز بخوانید تا با سلامت وارد بهشت شوید.»\n— ترمذی",
  "hadith80": "«هر کس از مردم سپاسگزار نباشد، از خداوند سپاسگزار نیست.»\n— ترمذی",
  "hadith81": "«حسد جایز نیست مگر در دو مورد: مردی که خداوند به او مال داده و او آن را در راه حق خرج می‌کند، و مردی که خداوند به او حکمت داده و او با آن قضاوت و تعلیم می‌دهد.»\n— بخاری و مسلم",
  "hadith82": "«انسان بر دین دوستش است، پس هر یک از شما بنگرد با چه کسی دوستی می‌کند.»\n— ابوداوود و ترمذی",
  "hadith85": "«هر کس چیزی را به خاطر خداوند ترک کند، خداوند بهتر از آن را جایگزین می‌کند.»\n— احمد",
  "hadith86": "«هر کس عیب مسلمانی را بپوشاند، خداوند عیب او را در روز قیامت می‌پوشاند.»\n— بخاری و مسلم",
  "hadith87": "«در دنیا چنان باش که گویی غریبه‌ای یا مسافری هستی.»\n— بخاری",
  "hadith88": "«هر کس بر شخصی در سختی آسان بگیرد، خداوند در دنیا و آخرت بر او آسان می‌گیرد.»\n— مسلم",
  "hadith89": "«اعمال بسته به نیت‌هاست.»\n— بخاری و مسلم",
  "hadith90": "«از گمان بپرهیزید، زیرا گمان دروغ‌ترین سخن است.»\n— بخاری و مسلم",
  "hadith93": "«با هم غذا بخورید و نام خدا را ببرید تا برایتان برکت داده شود.»\n— ابوداوود",
  "hadith94": "«بهترین مجلس وسیع‌ترین آن است.»\n— ابوداوود",
  "hadith95": "«ببخشایید تا بخشوده شوید.»\n— احمد",
  "hadith96": "«شترت را ببند و سپس بر خدا توکل کن.»\n— ترمذی",
  "hadith97": "«شگفتا از کار مؤمن که همه چیز برایش خیر است.»\n— مسلم",
  "hadith98": "«مسلمان برادر مسلمان است: به او ظلم نمی‌کند، رهایش نمی‌کند و تحقیرش نمی‌کند.»\n— مسلم"
}
