  "hadith10": "\"Kim gündə yüz dəfə 'SubhanAllahi və bihamdihi' desə, günahları bağışlanar, hətta dənizin köpüyü qədər olsa belə.\"\n— Buxari",
  "hadith11": "\"Ən xeyirli dua Ərəfə günü edilən duadır, məndən əvvəlki peyğəmbərlərin və mənim dediyim ən xeyirli söz: La ilahə illəllah.\"\n— Tirmizi",
  "hadith12": "\"Kim hər fərz namazdan sonra Ayətəl-Kürsi oxusa, onu cənnətə girməkdən yalnız ölüm saxlayar.\"\n— Nəsai",
  "hadith13": "\"Gözəl söz sədəqədir.\"\n— Buxari və Müslim",
  "hadith14": "\"Allaha və axirət gününə iman gətirən xeyir söyləsin və ya sussun.\"\n— Buxari və Müslim",
  "hadith15": "\"Dul qadına və miskinə baxan adam Allah yolunda mübarizə aparan kimidir.\"\n— Buxari",
  "hadith16": "\"Qardaşına təbəssüm etməyin sədəqədir.\"\n— Tirmizi",
  "hadith17": "\"Sizin ən xeyirliniz Quranı öyrənən və öyrədəndir.\"\n— Buxari",
  "hadith18": "\"Heç kəs öz əlinin zəhməti ilə qazandığından yaxşı yemək yeməmişdir.\"\n— Buxari",
  "hadith19": "\"Allah mülayimdir və hər işdə mülayimliyi sevir.\"\n— Buxari və Müslim",
  "settingsAbout": "Haqqında",
  "settingsVersion": "Versiya",
  "settingsDeveloper": "Tərtibatçı",
  "hadith50": "\"Allahın ən çox sevdiyi insanlar başqalarına ən çox fayda verənlərdir.\"\n— Təbərani",
  "hadith51": "\"Kim qəzəbini boğsa, halbuki onu həyata keçirə bilsə, Allah onu Qiyamət günü bütün yaradılmışların qarşısında çağırıb mükafatını seçməyini söyləyər.\"\n— Tirmizi",
  "hadith52": "\"Sədəqə verməyə tələsin, çünki o bəlanın qarşısını alır.\"\n— Tirmizi",
  "hadith53": "\"Heç bir yaxşılığı kiçik görmə, hətta qardaşını gülər üzlə qarşılamaq olsa belə.\"\n— Müslim",
  "hadith54": "\"Sizin ən xeyirliniz ailəsinə ən yaxşı davrananınızdır.\"\n— Tirmizi",
  "hadith55": "\"Kim gecə Bəqərə surəsinin son iki ayəsini oxusa, bu ona kifayət edər.\"\n— Buxari & Müslim",
  "hadith56": "\"Dünya bir nemətdir, ən yaxşı neməti isə saleh qadındır.\"\n— Müslim",
  "hadith57": "\"Üç dua geri qaytarılmaz: oruclunun duası, ədalətli hökmdarın duası və məzlumun duası.\"\n— Tirmizi",
  "hadith58": "\"Kim mənə bir dəfə salavat göndərsə, Allah ona on dəfə rəhmət edər.\"\n— Müslim",
  "hadith59": "\"Məscid hər təqvalı insanın evidir.\"\n— Təbərani",
  "hadith60": "\"Kim 'La həvlə və la qüvvətə illə billah' desə — bu doxsan doqquz xəstəliyin dərmanıdır, ən yüngülü narahatlıqdır.\"\n— Hakim",
  "hadith61": "\"Allah bir iş gördüyünüzdə onu ən yaxşı şəkildə görməyinizi sevir.\"\n— Təbərani",
  "hadith62": "\"Cənnət anaların ayaqları altındadır.\"\n— Nəsai",
  "hadith63": "\"Valideynlərə yaxşılıq ən böyük fərz əməldir.\"\n— Buxari",
  "hadith64": "\"Aza şükür edənə çox verilər.\"\n— Beyhəqi",
  "hadith65": "\"Mömin möminin güzgüsüdür.\"\n— Əbu Davud",
  "hadith66": "\"Doğruluq xeyirxahlığa aparır, xeyirxahlıq isə Cənnətə aparır.\"\n— Buxari & Müslim",
  "hadith67": "\"Əmanəti sənə etibar edənə qaytar, sənə xəyanət edənə xəyanət etmə.\"\n— Əbu Davud & Tirmizi",
  "hadith68": "\"Müsəlmana gələn yorğunluq, xəstəlik, kədər, qəm, əziyyət və ya narahatlıq, hətta bir tikan batması belə olsa, Allah onun günahlarının bir hissəsini bağışlayar.\"\n— Buxari & Müslim",
  "hadith69": "\"Müsəlmanın qardaşına qaib halında etdiyi dua həmişə qəbul olunar.\"\n— Müslim",
  "hadith70": "\"Kim Allahdan üç dəfə Cənnət istəsə, Cənnət deyər: Allahım, onu Cənnətə daxil et.\"\n— Tirmizi",
  "hadith71": "\"Ramazandan sonra ən fəzilətli oruc Allahın ayı Məhərrəm orucudur.\"\n— Müslim",
  "hadith72": "\"Kim həcc edib pis söz söyləməzsə və günah etməzsə, anasının onu doğduğu gündəki kimi qayıdar.\"\n— Buxari & Müslim",
  "hadith73": "\"Bir ümrə digər ümrəyə qədər aralarındakı günahların kəffarəsidir.\"\n— Buxari & Müslim",
  "hadith74": "\"Xeyirli işlərə yarışın.\"\n— Müslim",
  "hadith75": "\"Sübh namazının iki rəkəti dünyadan və ondakı hər şeydən xeyirlidir.\"\n— Müslim",
  "hadith76": "\"Kim mütəmadi istiğfar etsə, Allah ona hər çətinlikdən çıxış yolu verər.\"\n— Əbu Davud",
  "hadith77": "\"Əgər siz Allaha layiqincə təvəkkül etsəydiniz, O sizi quşları ruzilədirdiyi kimi ruziləndirərdi.\"\n— Tirmizi",
  "hadith78": "\"Kim xəstəni ziyarət etsə, qayıdana qədər cənnət bağındadır.\"\n— Müslim",
  "hadith79": "\"Salamı yayın, yemək verin və insanlar yatarkən gecə namazı qılın — cənnətə salamatlıqla girərsiniz.\"\n— Tirmizi",
  "hadith80": "\"Allahın ən sevdiyi əməl davamlı olanıdır, az olsa belə.\"\n— Buxari",
  "hadith81": "\"Qibtə yalnız iki halda icazəlidir: Allahın mal verib haqq yolunda xərcləyən adam, və Allahın hikmət verib onunla hökm çıxarıb öyrədən adam.\"\n— Buxari və Müslim",
  "hadith82": "\"İnsan dostunun dini üzərindədir, ona görə hər biriniz kiminlə dost olduğuna baxsın.\"\n— Əbu Davud və Tirmizi",
  "hadith83": "\"Ölümü çox xatırlayın, çünki o qəlbi təmizləyir.\"\n— Tirmizi",
  "hadith84": "\"Ən yaxşınız qəlbi ən yumşaq olanınızdır.\"\n— Təbərani",
  "hadith85": "\"Allah heç bir nəfəsə gücündən artıq yük yükləməz.\"\n— Quran 2:286",
  "hadith86": "\"Kim müsəlmanın eybini gizlətsə, Allah Qiyamət günü onun eybini gizlədər.\"\n— Buxari və Müslim",
  "hadith87": "\"Dünyada qərib və ya yolçu kimi ol.\"\n— Buxari",
  "hadith88": "\"Kim çətinlikdəki adama asanlıq etsə, Allah ona dünyada və axirətdə asanlıq edər.\"\n— Müslim",
  "hadith89": "\"Əməllərin mükafatı niyyətlərə bağlıdır.\"\n— Buxari və Müslim",
  "hadith90": "\"Şübhədən çəkinin, çünki şübhə ən yalan sözdür.\"\n— Buxari və Müslim",
  "hadith91": "\"Kim Allah xatirinə yalanı tərk etsə, zarafatda olsa belə, mən ona cənnətin kənarında bir saray zəmanəti verirəm.\"\n— Əbu Davud",
  "hadith92": "\"Xeyir qapıları çoxdur: Allahı təsbih etmək, Ona həmd etmək, sədəqə, yaxşılığa əmr etmək və yoldan əziyyəti qaldırmaq.\"\n— Müslim",
  "hadith93": "\"Birlikdə yeyin və Allahın adını çəkin, sizin üçün bərəkətli olacaq.\"\n— Əbu Davud",
  "hadith94": "\"Ən yaxşı məclis ən geniş olanıdır.\"\n— Əbu Davud",
  "hadith95": "\"Bağışlayın, siz də bağışlanacaqsınız.\"\n— Əhməd",
  "hadith96": "\"Dəvəni bağla, sonra Allaha təvəkkül et.\"\n— Tirmizi",
  "hadith97": "\"Möminin işi qəribədir — hər şey onun üçün xeyirdir.\"\n— Müslim",
  "hadith98": "\"Müsəlman müsəlmanın qardaşıdır: ona zülm etməz, onu tərk etməz, onu kiçik görməz.\"\n— Müslim",
  "hadith99": "\"Allahın ən sevdiyi söz: SubhanAllahi və bihamdihi, SubhanAllahil Azim.\"\n— Buxari və Müslim",
  "hadith20": "\"Kim Ramazanı iman və savab ümidi ilə oruc tutarsa, keçmiş günahları bağışlanar.\"\n— Buxari və Müslim",
  "hadith21": "\"Namaz dinin dirəyidir.\"\n— Beyhəqi",
  "hadith22": "\"Azan ilə iqamə arasındakı dua rədd edilməz.\"\n— Əbu Davud",
  "hadith23": "\"Kim Allah üçün bir məscid tikərsə, Allah onun üçün cənnətdə bir ev tikər.\"\n— Buxari və Müslim",
  "hadith24": "\"Kişilər üçün ən yaxşı cərgələr birinci cərgələr, qadınlar üçün ən yaxşı cərgələr isə son cərgələrdir.\"\n— Müslim",
  "hadith25": "\"Oruc cəhənnəm atəşindən bir qalxandır.\"\n— Nəsai",
  "hadith26": "\"Kim on iki rükət sünnət namazı qılarsa, onun üçün cənnətdə bir ev tikilər.\"\n— Müslim",
  "hadith27": "\"Quranı gözəl oxuyan şəxs kərim olan mələklərlə birlikdə olacaq.\"\n— Buxari və Müslim",
  "hadith28": "\"Elm öyrənmək hər bir müsəlmana vacibdir.\"\n— İbn Macə",
  "hadith29": "\"Sədəqənin ən yaxşısı su içirməkdir.\"\n— Əhməd",
  "hadith30": "\"Kim bir möminə bir çətinliyi aradan qaldırarsa, Allah da Qiyamət günü onun bir çətinliyini aradan qaldırar.\"\n— Müslim",
  "hadith31": "\"Mərhəmətli olanlara Rəhman olan Allah mərhəmət edər.\"\n— Əbu Davud və Tirmizi",
  "hadith32": "\"Həya imandandır.\"\n— Buxari və Müslim",
  "hadith33": "\"Təmizlik imanın yarısıdır.\"\n— Müslim",
  "hadith34": "\"Kim səbr edərsə, Allah ona səbr verər.\"\n— Buxari və Müslim",
  "hadith35": "\"Ən yaxşı sərvət Allahı zikr edən dildir.\"\n— Təbərani",
  "hadith36": "\"Heç biriniz özünə istədiyini qardaşına da istəmədikcə həqiqi iman etmiş olmaz.\"\n— Buxari və Müslim",
  "hadith37": "\"Acları doyurun, xəstələri ziyarət edin və əsirləri azad edin.\"\n— Buxari",
  "hadith38": "\"Güclü insan güləşdə qalib gələn deyil, qəzəb anında özünə hakim olandır.\"\n— Buxari və Müslim",
  "hadith39": "\"Kim dilini və namusunu qoruyarsa, mən ona cənnəti zəmanət verirəm.\"\n— Buxari",
  "hadith40": "\"Hər namazdan sonra otuz üç dəfə 'SubhanAllah', 'Əlhəmdulilləh' və 'Allahu Əkbər' deyin.\"\n— Müslim",
  "hadith41": "\"Ən yaxşı zikr La ilahə illəllahdır.\"\n— Tirmizi",
  "hadith42": "\"İnsanların çoxunun israf etdiyi iki nemət var: sağlamlıq və boş vaxt.\"\n— Buxari",
  "hadith43": "\"Beşdən əvvəl beşi qənimət bilin: qocalmadan gəncliyi, xəstəlikdən sağlamlığı, yoxsulluqdan varlığı, məşğuliyyətdən boş vaxtı və ölümdən həyatı.\"\n— Hakim",
  "hadith44": "\"Kim İxlas surəsini on dəfə oxuyarsa, Allah onun üçün cənnətdə bir ev tikər.\"\n— Əhməd",
  "hadith45": "\"Fərz namazlardan sonra ən yaxşı namaz gecə namazıdır.\"\n— Müslim",
  "hadith46": "\"Sədəqə günahları suyun odu söndürdüyü kimi söndürür.\"\n— Tirmizi",
  "hadith47": "\"Qohumluq əlaqəsini saxlayan ona qarşılıq verən deyil, əlaqəsi kəsilsə belə onu davam etdirəndir.\"\n— Buxari",
  "hadith48": "\"Hər xeyirli əməl sədəqədir.\"\n— Buxari və Müslim",
  "hadith49": "\"Kim yemək yeyib 'Əlhəmdulilləh' deyərsə, keçmiş günahları bağışlanar.\"\n— Tirmizi"
}
