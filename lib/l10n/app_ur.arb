  "sundayFull": "اتوار",
  "hadith0": "\"اللہ کے نزدیک سب سے محبوب عمل وہ ہے جو مسلسل کیا جائے، چاہے تھوڑا ہی ہو۔\"\n— بخاری و مسلم",
  "hadith2": "\"جب ابن آدم فوت ہو جاتا ہے تو اس کے اعمال منقطع ہو جاتے ہیں سوائے تین کے: صدقہ جاریہ، علم نافع، یا نیک اولاد جو اس کے لیے دعا کرے۔\"\n— مسلم",
  "hadith3": "\"جس نے دو ٹھنڈی نمازیں (فجر اور عصر) پڑھیں وہ جنت میں داخل ہو گا۔\"\n— بخاری",
  "hadith4": "\"اللہ تمہاری صورتوں اور مالوں کو نہیں دیکھتا بلکہ تمہارے دلوں اور اعمال کو دیکھتا ہے۔\"\n— مسلم",
  "hadith6": "\"آسانی کرو اور مشکل نہ بناؤ، خوشخبری دو اور لوگوں کو متنفر نہ کرو۔\"\n— بخاری",
  "hadith7": "\"جو شخص علم کی تلاش میں راستہ چلے، اللہ اس کے لیے جنت کا راستہ آسان کر دیتا ہے۔\"\n— مسلم",
  "hadith8": "\"صدقہ مال کو کم نہیں کرتا۔\"\n— مسلم",
  "hadith9": "\"طاقتور مومن اللہ کے نزدیک کمزور مومن سے بہتر اور زیادہ محبوب ہے، جبکہ دونوں میں خیر ہے۔\"\n— مسلم",
  "historyDayCompleted": "{total} میں سے {completed} مکمل",
  "settingsSchedule": "شیڈول",
  "settingsAppearance": "ظاہری شکل",
  "settingsAboutTagline": "آپ کا روزانہ دین ساتھی",
  "settingsRolloverSub": "دن کب ری سیٹ ہوتا ہے",
  "hadith10": "\"جو شخص دن میں سو بار 'سبحان اللہ وبحمدہ' کہے، اس کے گناہ معاف کر دیے جائیں گے چاہے سمندر کی جھاگ جتنے ہوں۔\"\n— بخاری و مسلم",
  "hadith12": "\"جو شخص ہر فرض نماز کے بعد آیۃ الکرسی پڑھے، جنت میں داخلے سے اسے صرف موت ہی روکتی ہے۔\"\n— نسائی",
  "hadith13": "\"اچھی بات صدقہ ہے۔\"\n— بخاری و مسلم",
  "hadith14": "\"جو اللہ اور آخرت کے دن پر ایمان رکھتا ہے وہ اچھی بات کہے یا خاموش رہے۔\"\n— بخاری و مسلم",
  "hadith15": "\"بیوہ اور مسکین کی دیکھ بھال کرنے والا اللہ کی راہ میں مجاہد کی طرح ہے۔\"\n— بخاری و مسلم",
  "hadith16": "\"اپنے بھائی کے سامنے مسکرانا صدقہ ہے۔\"\n— ترمذی",
  "hadith17": "\"تم میں سب سے بہتر وہ ہے جو قرآن سیکھے اور سکھائے۔\"\n— بخاری",
  "hadith18": "\"کسی نے اپنے ہاتھ کی کمائی سے بہتر کھانا نہیں کھایا۔\"\n— بخاری",
  "hadith19": "\"اللہ نرم ہے اور ہر معاملے میں نرمی پسند کرتا ہے۔\"\n— بخاری و مسلم",
  "settingsAbout": "معلومات",
  "settingsVersion": "ورژن",
  "settingsDeveloper": "ڈیولپر",
  "settingsSupport": "سپورٹ",
  "settingsRate": "ایپ کو ریٹ کریں",
  "settingsContact": "ہم سے رابطہ کریں",
  "settingsReportBug": "بگ کی اطلاع دیں",
  "settingsRequestFeature": "فیچر کی درخواست کریں",
  "settingsSupportFallback": "میل نہیں کھل سکی۔ براہ کرم {email} پر ای میل کریں۔",
  "settingsPrivacyPolicy": "رازداری کی پالیسی",
  "settingsPrivacyOpenFailed": "رازداری کی پالیسی نہیں کھل سکی۔",
  "hadith20": "\"جو شخص ایمان اور ثواب کی نیت سے رمضان کے روزے رکھے، اس کے پچھلے گناہ معاف کر دیے جائیں گے۔\"\n— بخاری و مسلم",
  "hadith22": "\"اذان اور اقامت کے درمیان کی دعا رد نہیں ہوتی۔\"\n— ابوداؤد",
  "hadith23": "\"جس نے اللہ کے لیے مسجد بنائی، اللہ اس کے لیے جنت میں گھر بنائے گا۔\"\n— بخاری و مسلم",
  "hadith24": "\"مردوں کی بہترین صفیں پہلی اور عورتوں کی بہترین صفیں آخری ہیں۔\"\n— مسلم",
  "hadith25": "\"روزہ جہنم کی آگ سے ڈھال ہے۔\"\n— نسائی",
  "hadith26": "\"جو بارہ رکعت سنت پڑھے، اس کے لیے جنت میں گھر بنایا جائے گا۔\"\n— مسلم",
  "hadith27": "\"قرآن میں ماہر معزز فرشتوں کے ساتھ ہوگا۔\"\n— بخاری و مسلم",
  "hadith29": "\"سب سے بہترین صدقہ پانی پلانا ہے۔\"\n— احمد",
  "hadith30": "\"جو شخص کسی مومن سے ایک تکلیف دور کرے، اللہ قیامت کے دن اس سے ایک تکلیف دور فرمائے گا۔\"\n— مسلم",
  "hadith32": "\"حیا ایمان کا حصہ ہے۔\"\n— بخاری و مسلم",
  "hadith34": "\"جو صبر کرے، اللہ اسے صبر عطا فرماتا ہے۔\"\n— بخاری و مسلم",
  "hadith36": "\"تم میں سے کوئی اس وقت تک مومن نہیں ہو سکتا جب تک وہ اپنے بھائی کے لیے وہی پسند نہ کرے جو اپنے لیے کرتا ہے۔\"\n— بخاری و مسلم",
  "hadith37": "\"بھوکوں کو کھانا کھلاؤ، بیماروں کی عیادت کرو اور قیدیوں کو آزاد کرو۔\"\n— بخاری",
  "hadith38": "\"طاقتور وہ نہیں جو پہلوان ہو، بلکہ طاقتور وہ ہے جو غصے میں خود پر قابو رکھے۔\"\n— بخاری و مسلم",
  "hadith40": "\"ہر نماز کے بعد تینتیس بار 'سبحان اللہ'، 'الحمد للہ' اور 'اللہ اکبر' کہو۔\"\n— مسلم",
  "hadith41": "\"سب سے بہترین ذکر لا إله إلا الله ہے۔\"\n— ترمذی",
  "hadith42": "\"دو نعمتیں ہیں جن میں بہت سے لوگ خسارے میں ہیں: صحت اور فراغت۔\"\n— بخاری",
  "hadith43": "\"پانچ چیزوں کو پانچ سے پہلے غنیمت جانو: جوانی کو بڑھاپے سے پہلے، صحت کو بیماری سے پہلے، مالداری کو غربت سے پہلے، فراغت کو مشغولیت سے پہلے اور زندگی کو موت سے پہلے۔\"\n— حاکم",
  "hadith44": "\"جو شخص سورۃ الاخلاص دس بار پڑھے، اللہ اس کے لیے جنت میں ایک گھر بنائے گا۔\"\n— احمد",
  "hadith45": "\"فرض نمازوں کے بعد سب سے بہترین نماز رات کی نماز ہے۔\"\n— مسلم",
  "hadith46": "\"صدقہ گناہوں کو اس طرح بجھا دیتا ہے جیسے پانی آگ کو بجھاتا ہے۔\"\n— ترمذی",
  "hadith47": "\"صلہ رحمی کرنے والا وہ نہیں جو بدلہ دے، بلکہ وہ ہے جو قطع رحمی ہونے کے باوجود رشتے جوڑے۔\"\n— بخاری",
  "hadith49": "\"جو شخص کھانا کھائے اور کہے: 'اللہ کا شکر ہے جس نے مجھے یہ کھلایا اور میری کسی طاقت اور قوت کے بغیر مہیا کیا'، اس کے پچھلے گناہ معاف کر دیے جائیں گے۔\"\n— ترمذی",
  "hadith53": "\"کسی بھی نیکی کو حقیر نہ سمجھو، چاہے وہ اپنے بھائی سے خندہ پیشانی سے ملنا ہی ہو۔\"\n— مسلم",
  "hadith54": "\"تم میں سے بہترین وہ ہے جو اپنے گھر والوں کے لیے بہترین ہو۔\"\n— ترمذی",
  "hadith55": "\"جو شخص رات کو سورۃ البقرہ کی آخری دو آیات پڑھے، وہ اس کے لیے کافی ہیں۔\"\n— بخاری و مسلم",
  "hadith56": "\"دنیا ایک سامان ہے اور اس کا بہترین سامان نیک بیوی ہے۔\"\n— مسلم",
  "hadith57": "\"تین دعائیں رد نہیں ہوتیں: روزے دار کی دعا، عادل حاکم کی دعا اور مظلوم کی دعا۔\"\n— ترمذی",
  "hadith58": "\"جو مجھ پر ایک بار درود بھیجے، اللہ اس پر دس بار رحمت نازل فرماتا ہے۔\"\n— مسلم",
  "hadith65": "\"مومن مومن کا آئینہ ہے۔\"\n— ابو داؤد",
  "hadith66": "\"سچائی نیکی کی طرف لے جاتی ہے اور نیکی جنت کی طرف لے جاتی ہے۔\"\n— بخاری و مسلم",
  "hadith67": "\"امانت اس کو لوٹاؤ جس نے تمہیں امانت دی، اور جس نے تمہارے ساتھ خیانت کی اس سے خیانت نہ کرو۔\"\n— ابو داؤد و ترمذی",
  "hadith68": "\"مسلمان کو جو بھی تھکان، بیماری، غم، دکھ، تکلیف یا پریشانی پہنچتی ہے، یہاں تک کہ ایک کانٹا بھی چبھ جائے، اللہ اس کے بدلے اس کے کچھ گناہ معاف فرما دیتا ہے۔\"\n— بخاری و مسلم",
  "hadith69": "\"مسلمان کی اپنے بھائی کے لیے غیر حاضری میں دعا ہمیشہ قبول ہوتی ہے۔\"\n— مسلم",
  "hadith70": "\"جو شخص اللہ سے تین بار جنت مانگے، جنت کہتی ہے: اے اللہ اسے جنت میں داخل فرما۔\"\n— ترمذی",
  "hadith71": "\"رمضان کے بعد سب سے افضل روزہ اللہ کے مہینے محرم کا روزہ ہے۔\"\n— مسلم",
  "hadith72": "\"جس نے حج کیا اور کوئی فحش بات یا گناہ نہ کیا، وہ ایسے لوٹتا ہے جیسے اس دن جب اس کی ماں نے اسے جنم دیا تھا۔\"\n— بخاری و مسلم",
  "hadith73": "\"ایک عمرہ سے دوسرے عمرہ تک کا درمیانی وقت دونوں کے بیچ کے گناہوں کا کفارہ ہے۔\"\n— بخاری و مسلم",
  "hadith74": "\"نیکیوں کی طرف جلدی کرو اس سے پہلے کہ اندھیری رات کے ٹکڑوں جیسے فتنے آ جائیں۔\"\n— مسلم",
  "hadith75": "\"فجر کی دو رکعتیں دنیا اور اس کی ہر چیز سے بہتر ہیں۔\"\n— مسلم",
  "hadith77": "\"اگر تم اللہ پر اس طرح توکل کرو جیسا کہ توکل کا حق ہے، تو وہ تمہیں اسی طرح رزق دے گا جیسا کہ پرندوں کو دیتا ہے۔\"\n— ترمذی",
  "hadith78": "\"جو شخص کسی بیمار کی عیادت کرتا ہے، وہ واپس آنے تک جنت کے باغ میں رہتا ہے۔\"\n— مسلم",
  "hadith79": "\"سلام پھیلاؤ، کھانا کھلاؤ، اور رات کو نماز پڑھو جب لوگ سوئے ہوں — تم سلامتی سے جنت میں داخل ہو جاؤ گے۔\"\n— ترمذی",
  "hadith80": "\"جو لوگوں کا شکر نہیں کرتا وہ اللہ کا شکر نہیں کرتا۔\"\n— ترمذی",
  "hadith81": "\"حسد صرف دو باتوں میں جائز ہے: وہ شخص جسے اللہ نے مال دیا اور وہ اسے حق کے راستے میں خرچ کرتا ہے، اور وہ شخص جسے اللہ نے حکمت دی اور وہ اس سے فیصلہ کرتا ہے اور سکھاتا ہے۔\"\n— بخاری و مسلم",
  "hadith82": "\"انسان اپنے دوست کے دین پر ہوتا ہے، پس تم میں سے ہر ایک دیکھ لے کہ وہ کس سے دوستی کرتا ہے۔\"\n— ابوداؤد و ترمذی",
  "hadith85": "\"جو شخص اللہ کی خاطر کوئی چیز چھوڑ دے، اللہ اسے اس سے بہتر چیز عطا فرمائے گا۔\"\n— احمد",
  "hadith86": "\"جو شخص کسی مسلمان کے عیب چھپائے، اللہ قیامت کے دن اس کے عیب چھپائے گا۔\"\n— بخاری و مسلم",
  "hadith87": "\"دنیا میں ایسے رہو جیسے تم اجنبی ہو یا مسافر۔\"\n— بخاری",
  "hadith88": "\"جو شخص کسی مشکل میں مبتلا کے لیے آسانی کرے، اللہ دنیا اور آخرت میں اس کے لیے آسانی فرمائے گا۔\"\n— مسلم",
  "hadith89": "\"اعمال کا دارومدار نیتوں پر ہے۔\"\n— بخاری و مسلم",
  "hadith90": "\"بدگمانی سے بچو کیونکہ بدگمانی سب سے جھوٹی بات ہے۔\"\n— بخاری و مسلم",
  "hadith93": "\"اکٹھے کھاؤ اور اللہ کا نام لو، تمہارے لیے برکت ہوگی۔\"\n— ابوداؤد",
  "hadith94": "\"جب بھی کوئی قوم اللہ کا ذکر کرنے کے لیے بیٹھتی ہے تو فرشتے ان کو گھیر لیتے ہیں، رحمت ان کو ڈھانپ لیتی ہے اور سکینہ ان پر نازل ہوتا ہے۔\"\n— مسلم",
  "hadith95": "\"اللہ معاف کرنے والے بندے کی عزت ہی بڑھاتا ہے۔\"\n— مسلم",
  "hadith96": "\"اپنی اونٹنی باندھو اور پھر اللہ پر توکل کرو۔\"\n— ترمذی",
  "hadith97": "\"مومن کا معاملہ عجیب ہے — اس کی ہر بات اس کے لیے خیر ہے۔\"\n— مسلم",
  "hadith98": "\"مسلمان مسلمان کا بھائی ہے: وہ اس پر ظلم نہیں کرتا، نہ اسے چھوڑتا ہے، نہ اسے حقیر جانتا ہے۔\"\n— مسلم"
}
