  "sundayFull": "یکشنبه",
  "hadith0": "\"د الله تعالی ته ترټولو خوښې عملونه هغه دي چې پرې دوام وشي، که لږ هم وي.\"\n— بخاري او مسلم",
  "hadith1": "\"نیک عملونه هومره واخلئ څومره چې وکولی شئ، ځکه ترټولو غوره عملونه هغه دي چې دوامداره وي که لږ هم وي.\"\n— ابن ماجه",
  "hadith2": "\"کله چې د آدم زوی مړ شي، عملونه یې ودریږي پرته له دریو: صدقه جاریه، ګټور علم، یا نیک اولاد چې د هغه لپاره دعا کوي.\"\n— مسلم",
  "hadith3": "\"هر څوک چې دوه یخې لمونځونه (سهار او مازدیګر) وکړي، جنت ته به داخل شي.\"\n— بخاري",
  "hadith4": "\"الله ستاسو بڼه او شتمنۍ ته نه ګوري، بلکې ستاسو زړونو او عملونو ته ګوري.\"\n— مسلم",
  "hadith5": "\"ترټولو غوره خلک هغه دي چې خلکو ته ترټولو ډیر ګټور وي.\"\n— طبراني",
  "hadith6": "\"کارونه اسانه کړئ او سخت یې مه کوئ، زېری ورکړئ او خلک مه ډارئ.\"\n— بخاري",
  "hadith7": "\"هر څوک چې د علم په لټه کې لاره ووهي، الله به ورته جنت ته لاره اسانه کړي.\"\n— مسلم",
  "hadith8": "\"صدقه مال نه کموي.\"\n— مسلم",
  "hadith9": "\"قوي مؤمن د الله سره غوره او ډیر خوښ دی د ضعیف مؤمن په پرتله، خو په دواړو کې خیر شته.\"\n— مسلم",
  "historyDayCompleted": "{total} څخه {completed} بشپړ شوي",
  "settingsSchedule": "مهالویش",
  "settingsAppearance": "بڼه",
  "settingsAboutTagline": "ستاسو ورځنی دیني ملګری",
  "settingsRolloverSub": "ورځ کله بیا پیلیږي",
  "hadith10": "\"هر څوک چې په ورځ کې سل ځله 'سبحان الله وبحمده' ووایی، د هغه ګناهونه بخښل کیږی که چیرې د سمندر د ګاز په شان وی.\"\n— بخاري",
  "hadith11": "\"غوره دعا د عرفې د ورځې دعا ده، او غوره خبره چې ما او ما نه مخکې پیغمبرانو ویلې: لا اله الا الله.\"\n— ترمذي",
  "hadith12": "\"هر څوک چې د هر فرض لمانځه وروسته آیت الکرسی ووایی، جنت ته د ننوتلو مخه یې یوازې مرګ نیسی.\"\n— نسائي",
  "hadith13": "\"ښه خبره صدقه ده.\"\n— بخاري او مسلم",
  "hadith14": "\"هر څوک چې پر الله او وروستي ورځ ایمان لری، دی باید ښه خبره وکړی یا چوپ وی.\"\n— بخاري او مسلم",
  "hadith15": "\"هغه څوک چې د کونډې او مسکین خیال ساتي د الله په لاره کې د مجاهد په شان دی.\"\n— بخاري",
  "hadith16": "\"د خپل ورور مخ ته خندل صدقه ده.\"\n— ترمذي",
  "hadith17": "\"ستاسو تر ټولو غوره هغه دی چې قرآن زده کوی او ورته ښوونه ورکوی.\"\n— بخاري",
  "hadith18": "\"هیچا چا د خپل لاس له کار نه ښه خواړه نه دي خوړلي.\"\n— بخاري",
  "hadith19": "\"الله نرم دی او په هر کار کې نرمي خوښوي.\"\n— بخاري او مسلم",
  "settingsAbout": "په اړه",
  "settingsVersion": "نسخه",
  "settingsDeveloper": "جوړونکی",
  "settingsSupport": "ملاتړ",
  "settingsRate": "اپلیکیشن ته درجه ورکړئ",
  "settingsContact": "موږ سره اړیکه ونیسئ",
  "settingsReportBug": "د ستونزې راپور ورکړئ",
  "settingsRequestFeature": "د ځانګړنې غوښتنه وکړئ",
  "settingsSupportFallback": "بریښنالیک نه خلاصیږي. مهرباني وکړئ {email} ته بریښنالیک ولیږئ.",
  "hadith50": "\"د الله تعالی نزد ترټولو خوښ هغه خلک دي چې نورو ته ترټولو ډېر ګټور وي.\"\n— طبراني",
  "hadith51": "\"هر څوک چې خپله قهر ونیسي پداسې حال کې چې د عمل کولو وړتیا ولري، الله به یې د قیامت په ورځ د ټولو مخلوقاتو په وړاندې وبولي ترڅو خپل انعام غوره کړي.\"\n— ترمذي",
  "hadith52": "\"په صدقه کې ژر اقدام وکړئ، ځکه چې صدقه د بلا مخه نیسي.\"\n— ترمذي",
  "hadith53": "\"هېڅ نېکي مه حقیره ګڼئ، که څه هم دا وي چې خپل ورور ته په خندا مخ ووینئ.\"\n— مسلم",
  "hadith54": "\"ستاسو تر ټولو غوره هغه دی چې د خپلې کورنۍ لپاره غوره وي.\"\n— ترمذي",
  "hadith55": "\"هر څوک چې شپه د سورة البقرة وروستۍ دوه آیتونه ولولي، دا به ورته بسنه وي.\"\n— بخاري او مسلم",
  "hadith56": "\"دنیا یو متاع دی، او د دې ترټولو غوره متاع نېکه ښځه ده.\"\n— مسلم",
  "hadith57": "\"درې دعاوې رد نه کیږي: د روژه نیونکي دعا، د عادل حاکم دعا، او د مظلوم دعا.\"\n— ترمذي",
  "hadith58": "\"هر څوک چې پر ما یو ځل درود واستوي، الله به پرې لس ځله رحمت واستوي.\"\n— مسلم",
  "hadith59": "\"جومات د هر متقي کس کور دی.\"\n— طبراني",
  "hadith60": "\"هر څوک چې 'لا حول ولا قوة الا بالله' ووایي — دا د نهه نوي ناروغیو درمل دی، چې ترټولو لږ یې اندیښنه ده.\"\n— حاکم",
  "hadith61": "\"الله خوښوي چې کله تاسو کار کوئ، هغه په غوره ډول ترسره کړئ.\"\n— طبراني",
  "hadith62": "\"جنت د مورو د پښو لاندې دی.\"\n— نسائي",
  "hadith63": "\"د الله تعالی نزد ترټولو خوښ عملونه: لمونځ په خپل وخت، بیا د والدینو سره نېکي، بیا د الله په لاره کې جهاد.\"\n— بخاري او مسلم",
  "hadith64": "\"هر څوک چې په لږ شکر وکړي، ورته به ډېر ورکړل شي.\"\n— بیهقي",
  "hadith65": "\"مؤمن د مؤمن آینه دی.\"\n— ابو داود",
  "hadith66": "\"ریښتینتوب نېکۍ ته رسوي، او نېکي جنت ته رسوي.\"\n— بخاري او مسلم",
  "hadith67": "\"امانت هغه چا ته ورکړه چې تاته یې سپارلې ده، او هغه چا ته خیانت مه کوه چې تاته یې خیانت کړی وي.\"\n— ابو داود او ترمذي",
  "hadith68": "\"هیڅ ستړتیا، ناروغي، غم، خپګان، تکلیف، یا پریشاني مسلمان ته نه رسیږي، حتی یوه اغزه هم، مګر الله د هغې په بدل کې د هغه ګناهونه معاف کوي.\"\n— بخاري او مسلم",
  "hadith69": "\"د مسلمان دعا د خپل ورور لپاره چې حاضر نه وي تل قبلیږي.\"\n— مسلم",
  "hadith70": "\"هر څوک چې له الله نه درې ځله جنت وغواړي، جنت وایي: الهي دا جنت ته داخل کړه.\"\n— ترمذي",
  "hadith71": "\"د رمضان وروسته ترټولو غوره روژه د الله میاشت محرم ده.\"\n— مسلم",
  "hadith72": "\"هر څوک چې حج وکړي او بده خبره او ګناه ونه کړي، هغه داسې راګرځي لکه هغه ورځ چې مور یې زیږولی وو.\"\n— بخاري او مسلم",
  "hadith73": "\"عمره تر بلې عمرې د دواړو ترمنځ ګناهونو کفاره ده.\"\n— بخاري او مسلم",
  "hadith74": "\"مخکې له دې چې فتنې د توره شپې د ټوټو په شان راشي، نېکو عملونو ته ولاړ شئ.\"\n— مسلم",
  "hadith75": "\"د سهار دوه رکعتونه د دنیا او هرڅه چې پکې دي نه ښې دي.\"\n— مسلم",
  "hadith76": "\"هرڅوک چې په منظم ډول استغفار کوي، الله به ورته د هرې ستونزې څخه لاره پیدا کړي.\"\n— ابوداود",
  "hadith77": "\"که تاسو په الله باندې داسې توکل کوئ لکه چې حق یې دی، نو هغه به تاسو ته داسې روزي درکوي لکه چې مرغیو ته ورکوي.\"\n— ترمذي",
  "hadith78": "\"هرڅوک چې ناروغ ته ځي، تر بیرته راتلو پورې د جنت په باغ کې وي.\"\n— مسلم",
  "hadith79": "\"سلام خپور کړئ، ډوډۍ ورکړئ، او شپه لمونځ وکړئ کله چې خلک ویده وي — تاسو به په سلامت سره جنت ته ننوځئ.\"\n— ترمذي",
  "hadith80": "\"هر څوک چې د خلکو شکرګزار نه وي، د الله شکرګزار نه دی.\"\n— ترمذي",
  "hadith81": "\"حسد یوازې په دوه حالتونو کې روا دی: هغه سړی چې الله ورته مال ورکړی او هغه یې په حق لاره خرڅ کوي، او هغه سړی چې الله ورته حکمت ورکړی او هغه ورسره فیصله کوي او ښوونه کوي.\"\n— بخاري او مسلم",
  "hadith82": "\"انسان د خپل ملګري په دین باندې دی، نو هر یو ستاسو دې وګوري چې د چا سره ملګرتیا کوي.\"\n— ابوداود او ترمذي",
  "hadith83": "\"مرګ ډیر یاد کړئ، ځکه چې دا زړه پاکوي.\"\n— ترمذي",
  "hadith84": "\"ترټولو غوره عبادت د خلاصون انتظار دی.\"\n— ترمذي",
  "hadith85": "\"هر څوک چې د الله لپاره یو شی پریږدي، الله به ورته غوره شی ورکړي.\"\n— احمد",
  "hadith86": "\"هرڅوک چې د مسلمان عیبونه پټ کړي، الله به د قیامت په ورځ د هغه عیبونه پټ کړي.\"\n— بخاري او مسلم",
  "hadith87": "\"په دنیا کې داسې اوسه لکه چې مسافر یې یا لاریون.\"\n— بخاري",
  "hadith88": "\"هرڅوک چې د ستونزمن لپاره اسانتیا وکړي، الله به په دنیا او آخرت کې ورته اسانتیا وکړي.\"\n— مسلم",
  "hadith89": "\"عملونه د نیتونو پورې تړلي دي.\"\n— بخاري او مسلم",
  "hadith90": "\"له بدګمانۍ څخه ځان ساتئ، ځکه چې بدګماني تر ټولو دروغجنه خبره ده.\"\n— بخاري او مسلم",
  "hadith91": "\"هرڅوک چې د الله لپاره دروغ پریږدي، حتی په ټوکو کې هم، زه ورته د جنت په څنډه کې ماڼۍ تضمینوم.\"\n— ابوداود",
  "hadith92": "\"د نیکۍ دروازې ډیرې دي: د الله تسبیح، د هغه حمد، صدقه، د نیکۍ امر، او له لارې د تکلیف لرې کول.\"\n— مسلم",
  "hadith93": "\"یوځای خوراک وکړئ او د الله نوم واخلئ، نو ستاسو لپاره به برکت وي.\"\n— ابوداود",
  "hadith94": "\"غوره مجلس هغه دی چې تر ټولو پراخه وي.\"\n— ابوداود",
  "hadith95": "\"وبخښئ، نو تاسو هم بخښل کیږئ.\"\n— احمد",
  "hadith96": "\"خپل اوښ وتړه بیا په الله توکل وکړه.\"\n— ترمذي",
  "hadith97": "\"د مؤمن کار عجیب دی — هر څه ورته ښه دي.\"\n— مسلم",
  "hadith98": "\"مسلمان د مسلمان ورور دی: نه پرې ظلم کوي، نه یې پریږدي، نه یې سپکوي.\"\n— مسلم",
  "hadith99": "\"د الله نزد تر ټولو ګرانه خبره: سبحان الله وبحمده، سبحان الله العظیم.\"\n— بخاري او مسلم",
  "hadith20": "\"هر څوک چې د ایمان او ثواب په نیت رمضان روژه ونیسي، د هغه تیرې ګناهونه بخښل کیږي.\"\n— بخاري او مسلم",
  "hadith21": "\"لمونځ د دین ستنه ده.\"\n— بیهقي",
  "hadith22": "\"د اذان او اقامت ترمنځ دعا رد نه کیږي.\"\n— ابو داود",
  "hadith23": "\"هر څوک چې د الله لپاره جومات جوړ کړي، الله به ورته په جنت کې کور جوړ کړي.\"\n— بخاري او مسلم",
  "hadith24": "\"د نارینه وو لپاره غوره صفونه لومړي صفونه دي، او د ښځو لپاره غوره صفونه وروستي صفونه دي.\"\n— مسلم",
  "hadith25": "\"روژه د دوزخ نه ساتنه ده.\"\n— نسائي",
  "hadith26": "\"هر څوک چې دولس رکعته سنت لمونځ وکړي، ورته به په جنت کې کور جوړ شي.\"\n— مسلم",
  "hadith27": "\"هغه څوک چې په قرآن کې ماهر وي، د عزتمنو پرښتو سره وي.\"\n— بخاري او مسلم",
  "hadith28": "\"د علم لټول د هر مسلمان فرض دی.\"\n— ابن ماجه",
  "hadith29": "\"غوره صدقه د اوبو ورکول دي.\"\n— احمد",
  "hadith30": "\"هر څوک چې له مؤمن څخه سختي لرې کړي، الله به ورته د قیامت په ورځ سختي لرې کړي.\"\n— مسلم",
  "hadith31": "\"رحم کوونکو ته رحمان رحم کوي.\"\n— ابو داود او ترمذي",
  "hadith32": "\"حیا د ایمان برخه ده.\"\n— بخاري او مسلم",
  "hadith33": "\"پاکوالی نیم ایمان دی.\"\n— مسلم",
  "hadith34": "\"هر څوک چې صبر وکړي، الله به ورته صبر ورکړي.\"\n— بخاري او مسلم",
  "hadith35": "\"غوره شتمني هغه ژبه ده چې الله یادوي.\"\n— طبراني",
  "hadith36": "\"ستاسو هیڅ یو ریښتینی مؤمن نه دی تر هغه چې خپل ورور ته هغه خوښ نه کړي چې ځان ته یې خوښوي.\"\n— بخاري او مسلم",
  "hadith37": "\"وږي خوراک ورکړئ، ناروغ یې ولیدئ، او بندیان آزاد کړئ.\"\n— بخاري",
  "hadith38": "\"قوي سړی هغه نه دی چې لوبې کوي، بلکې هغه دی چې په غصه کې ځان کنترولوي.\"\n— بخاري او مسلم",
  "hadith39": "\"هر څوک چې خپله ژبه او عزت وساتي، زه ورته جنت تضمین کوم.\"\n— بخاري",
  "hadith40": "\"د هر لمونځ وروسته درې دېرش ځله 'سبحان الله'، 'الحمد لله' او 'الله اکبر' ووایئ.\"\n— مسلم",
  "hadith41": "\"غوره ذکر 'لا اله الا الله' دی.\"\n— ترمذي",
  "hadith42": "\"دوه نعمتونه شته چې ډیری خلک یې ضایع کوي: روغتیا او خالي وخت.\"\n— بخاري",
  "hadith43": "\"پنځه شیان دمخه غنیمت وګڼئ: ځوانتوب دمخه له زوړتیا، روغتیا دمخه له ناروغۍ، شتمني دمخه له غربت، خالي وخت دمخه له بوختیا، او ژوند دمخه له مرګ.\"\n— حاکم",
  "hadith44": "\"هر څوک چې سوره اخلاص لس ځله ووایی، الله به ورته په جنت کې کور جوړ کړي.\"\n— احمد",
  "hadith45": "\"د فرض لمونځونو وروسته غوره لمونځ د شپې لمونځ دی.\"\n— مسلم",
  "hadith46": "\"صدقه ګناهونه هغسې ګل کوي لکه اوبه اور.\"\n— ترمذي",
  "hadith47": "\"صله رحمي کوونکی هغه نه دی چې بدله کوي، بلکې هغه دی چې کله رابطه پرې کړل شي بیا هم یې ساتي.\"\n— بخاري",
  "hadith48": "\"هره نیکي صدقه ده.\"\n— بخاري او مسلم",
  "hadith49": "\"هر څوک چې خوراک وخوري او ووایي: 'الحمدلله چې ما ته یې دا خوراک ورکړ او بې له کومې ځواکې یا طاقتې زما ما ته رسولی دی،' د هغه تېرې ګناهونه بخښل کیږي.\"\n— ترمذي"
}
