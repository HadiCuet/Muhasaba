  "hadith0": "\"Veprat me te dashura tek Allahu jane ato qe behen rregullisht, edhe nese jane te vogla.\"\n— Buhariu & Muslimi",
  "hadith1": "\"Merrni persiper vepra te mira aq sa keni mundesi, sepse veprat me te mira jane ato qe behen rregullisht edhe nese jane te pakta.\"\n— Ibn Maxhe",
  "hadith2": "\"Kur vdes biri i Ademit, veprat e tij nderpiten perveq trive: sadakaja e vazhdueshme, dituria e dobishme, ose femija i mire qe lutet per te.\"\n— Muslimi",
  "hadith3": "\"Kush i fal dy namazet e ftohta (Sabahun dhe Ikindinë) do te hyje ne Xhenet.\"\n— Buhariu",
  "hadith4": "\"Allahu nuk shikon pamjen tuaj as pasurine tuaj, por shikon zemrat tuaja dhe veprat tuaja.\"\n— Muslimi",
  "hadith5": "\"Me te miret e njerezve jane ata qe jane me te dobishmit per njerezit.\"\n— Darekutniu",
  "hadith6": "\"Lehtesoni dhe mos veshtiresoni; pergezoni dhe mos i trembni njerezit.\"\n— Buhariu",
  "hadith7": "\"Ai qe ndjek nje rruge per kerkim te dijes, Allahu ia lehtesonshtegen per ne Xhenet.\"\n— Muslimi",
  "hadith8": "\"Sadakaja nuk e pakeson pasurine.\"\n— Muslimi",
  "hadith9": "\"Besimtari i forte eshte me i mire dhe me i dashur tek Allahu sesa besimtari i dobet, ndersa te dy kane te mire.\"\n— Muslimi",
  "historyDayCompleted": "{completed} nga {total} të përfunduara",
  "settingsSchedule": "Orari",
  "settingsAppearance": "Pamja",
  "settingsAboutTagline": "Shoqëruesi juaj i përditshëm i dinit",
  "settingsRolloverSub": "Kur rifreskohet dita",
  "hadith10": "\"Kush thotë 'SubhanAllah ue bihamdihi' njëqind herë në ditë, mëkatet e tij do të falen edhe sikur të ishin si shkuma e detit.\"\n— Buhariu",
  "hadith11": "\"Lutja më e mirë është ajo e ditës së Arafatit, dhe fjala më e mirë që unë dhe profetët para meje kemi thënë: La ilahe il-lAllah.\"\n— Tirmidhiu",
  "hadith12": "\"Kush lexon Ajetul-Kursinë pas çdo namazi farz, asgjë nuk e pengon nga hyrja në Xhenet përveç vdekjes.\"\n— Nesaiu",
  "hadith13": "\"Fjala e mirë është sadaka.\"\n— Buhariu & Muslimi",
  "hadith14": "\"Kush beson në Allahun dhe Ditën e Fundit, le të thotë fjalë të mirë ose le të heshtë.\"\n— Buhariu & Muslimi",
  "hadith15": "\"Ai që kujdeset për të vejën dhe të varfrin, është si luftëtar në rrugën e Allahut.\"\n— Buhariu",
  "hadith16": "\"Buzëqeshja ndaj vëllait tënd është sadaka.\"\n— Tirmidhiu",
  "hadith17": "\"Më i miri prej jush është ai që e mëson Kuranin dhe ua mëson të tjerëve.\"\n— Buhariu",
  "hadith18": "\"Askush nuk ka ngrënë ushqim më të mirë sesa atë që e fiton me punën e duarve të veta.\"\n— Buhariu",
  "hadith19": "\"Allahu është i butë dhe e do butësinë në çdo gjë.\"\n— Buhariu & Muslimi"
}
