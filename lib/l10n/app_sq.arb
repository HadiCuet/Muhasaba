  "settingsSupportFallback": "Posta nuk u hap. Ju lutemi shkruani në {email}.",
  "hadith53": "\"Mos e nënvlerëso asnjë vepër të mirë, qoftë edhe takimi me vëllanë tënd me fytyrë të buzëqeshur.\"\n— Muslim",
  "hadith54": "\"Më i miri prej jush është ai që është më i mirë me familjen e tij.\"\n— Tirmidhi",
  "hadith55": "\"Kush i lexon dy ajetet e fundit të sures El-Bekare natën, ato i mjaftojnë atij.\"\n— Bukhari & Muslim",
  "hadith56": "\"Kjo botë është furnizim, dhe furnizimi më i mirë është gruaja e devotshme.\"\n— Muslim",
  "hadith57": "\"Tri lutje nuk refuzohen: lutja e agjëruesit, lutja e udhëheqësit të drejtë dhe lutja e të shtypurit.\"\n— Tirmidhi",
  "hadith58": "\"Kush dërgon salavat mbi mua një herë, Allahu dërgon dhjetë herë mëshirë mbi të.\"\n— Muslim",
  "hadith65": "\"Besimtari është pasqyra e besimtarit.\"\n— Abu Dawud",
  "hadith66": "\"Sinqeriteti çon tek mirësia, dhe mirësia çon tek Xheneti.\"\n— Bukhari & Muslim",
  "hadith67": "\"Ktheja amanetin atij që ta besoi, dhe mos e tradhëto atë që të tradhtoi.\"\n— Abu Dawud & Tirmidhi",
  "hadith68": "\"Asnjë lodhje, sëmundje, pikëllim, trishtim, dëm apo shqetësim nuk e godet muslimanin, madje as shpimi i një gjembi, veçse Allahu ia fshin disa nga mëkatet e tij.\"\n— Bukhari & Muslim",
  "hadith69": "\"Duaja e muslimanit për vëllanë e tij në mungesë të tij pranohet gjithmonë.\"\n— Muslim",
  "hadith70": "\"Kush i kërkon Allahut Xhenetin tri herë, Xheneti thotë: O Allah, fute atë në Xhenet.\"\n— Tirmidhi",
  "hadith71": "\"Agjërimi më i vlefshëm pas Ramazanit është agjërimi i muajit të Allahut, Muharremit.\"\n— Muslim",
  "hadith72": "\"Kush kryen haxhin dhe nuk flet fjalë të ndyta e nuk bën mëkat, kthehet si ditën kur e lindi nëna e tij.\"\n— Bukhari & Muslim",
  "hadith73": "\"Umra pas umres është shlyerje për mëkatet mes tyre.\"\n— Bukhari & Muslim",
  "hadith74": "\"Nxitoni në vepra të mira para se të vijnë sprovat si copa të një nate të errët.\"\n— Muslimi",
  "hadith75": "\"Dy rekatet e sabahut janë më të mira se bota dhe gjithçka që gjendet në të.\"\n— Muslimi",
  "hadith77": "\"Nëse do të mbështeteshit tek Allahu siç duhet, Ai do t'ju furnizonte ashtu siç i furnizon shpendët.\"\n— Tirmidhiu",
  "hadith78": "\"Kush viziton një të sëmurë, gjendet në kopshtin e xhenetit derisa të kthehet.\"\n— Muslimi",
  "hadith79": "\"Përhapni selamin, ushqeni të uriturit dhe faluni natën kur njerëzit flenë — do të hyni në xhenet me paqe.\"\n— Tirmidhiu",
  "hadith80": "\"Kush nuk është mirënjohës ndaj njerëzve, nuk është mirënjohës ndaj Allahut.\"\n— Tirmidhiu",
  "hadith81": "\"Smira nuk lejohet përveçse në dy raste: një njeri të cilit Allahu i ka dhënë pasuri dhe ai e shpenzon në rrugën e drejtë, dhe një njeri të cilit Allahu i ka dhënë urtësi dhe ai gjykon dhe mëson me të.\"\n— Buhariu dhe Muslimi",
  "hadith82": "\"Njeriu ndjek fenë e shokut të tij, prandaj le të shikojë secili prej jush me kë miqësohet.\"\n— Ebu Davudi dhe Tirmidhiu",
  "hadith85": "\"Kush lë diçka për hir të Allahut, Allahu e zëvendëson me diçka më të mirë.\"\n— Ahmedi",
  "hadith86": "\"Kush ia mbulon të metat një muslimani, Allahu do t'ia mbulojë të metat në Ditën e Gjykimit.\"\n— Buhariu dhe Muslimi",
  "hadith87": "\"Ji në këtë botë sikur të ishe i huaj ose udhëtar.\"\n— Buhariu",
  "hadith88": "\"Kush ia lehtëson dikujt në vështirësi, Allahu do t'ia lehtësojë atij në dynja dhe ahiret.\"\n— Muslimi",
  "hadith89": "\"Shpërblimi i veprave varet nga qëllimet.\"\n— Buhariu dhe Muslimi",
  "hadith90": "\"Largohuni nga dyshimi, sepse dyshimi është fjala më e rreme.\"\n— Buhariu dhe Muslimi",
  "hadith93": "\"Hani së bashku dhe përmendni emrin e Allahut, do të bekohet për ju.\"\n— Ebu Davudi",
  "hadith94": "\"Tubimi më i mirë është ai më i gjeri.\"\n— Ebu Davudi",
  "hadith95": "\"Falni dhe do të faleni.\"\n— Ahmedi",
  "hadith96": "\"Lidhe devenë tënde e pastaj mbështetu tek Allahu.\"\n— Tirmidhiu",
  "hadith97": "\"Sa e mrekullueshme është çështja e besimtarit — gjithçka është mirë për të.\"\n— Muslimi",
  "hadith98": "\"Muslimani është vëlla i muslimanit: nuk i bën padrejtësi, nuk e braktis dhe nuk e përbuz.\"\n— Muslimi",
  "hadith20": "\"Kush agjëron Ramazanin me besim dhe duke shpresuar shpërblimin, i falen mëkatet e kaluara.\"\n— Buhariu & Muslimi",
  "hadith22": "\"Lutja midis ezanit dhe ikametit nuk refuzohet.\"\n— Ebu Davudi",
  "hadith23": "\"Kush ndërton një xhami për Allahun, Allahu i ndërton atij një shtëpi në Xhenet.\"\n— Buhariu & Muslimi",
  "hadith24": "\"Safat më të mira për burrat janë të parat, ndërsa safat më të mira për gratë janë të fundit.\"\n— Muslimi",
  "hadith25": "\"Agjërimi është mburojë nga zjarri i Xhehenemit.\"\n— Nesaiu",
  "hadith26": "\"Kush fal dymbëdhjetë rekate sunet, i ndërtohet një shtëpi në Xhenet.\"\n— Muslimi",
  "hadith27": "\"Ai që e lexon bukur Kuranin do të jetë me engjëjt fisnikë.\"\n— Buhariu & Muslimi",
  "hadith29": "\"Sadakaja më e mirë është dhënia e ujit.\"\n— Ahmedi",
  "hadith30": "\"Kush ia largon një vështirësi besimtarit, Allahu do t'ia largojë një vështirësi atij në Ditën e Gjykimit.\"\n— Muslimi",
  "hadith32": "\"Turpi është pjesë e besimit.\"\n— Buhariu & Muslimi",
  "hadith34": "\"Kush duron, Allahu i jep durim.\"\n— Buhariu & Muslimi",
  "hadith36": "\"Askush prej jush nuk beson vërtet derisa t'i dojë vëllait të vet atë që i do vetes.\"\n— Buhariu & Muslimi",
  "hadith37": "\"Ushqeni të uriturit, vizitoni të sëmurët dhe lironi të robëruarit.\"\n— Buhariu",
  "hadith38": "\"I forti nuk është ai që mund në mundje, por ai që e kontrollon veten në zemërim.\"\n— Buhariu & Muslimi",
  "hadith40": "\"Thoni 'SubhanAllah', 'Elhamdulilah' dhe 'Allahu Ekber' tridhjetë e tri herë pas çdo namazi.\"\n— Muslimi",
  "hadith41": "\"Dhikri më i mirë është La ilahe il-lAllah.\"\n— Tirmidhiu",
  "hadith42": "\"Ka dy begatira që shumë njerëz i humbasin: shëndetin dhe kohën e lirë.\"\n— Buhariu",
  "hadith43": "\"Përfitoni pesë gjëra para pesë të tjerave: rininë para pleqërisë, shëndetin para sëmundjes, pasurinë para varfërisë, kohën e lirë para zënies dhe jetën para vdekjes.\"\n— Hakimi",
  "hadith44": "\"Kush lexon Suren Ihlas dhjetë herë, Allahu i ndërton atij një shtëpi në Xhenet.\"\n— Ahmedi",
  "hadith45": "\"Namazi më i mirë pas farzit është namazi i natës.\"\n— Muslimi",
  "hadith46": "\"Sadakaja i shuan mëkatet siç e shuan uji zjarrin.\"\n— Tirmidhiu",
  "hadith47": "\"Ai që i mban lidhjet farefisnore nuk është ai që i kthen vizitat, por ai që i mban edhe kur i shkëputen.\"\n— Buhariu",
  "hadith49": "\"Kush ha ushqim dhe thotë: 'Falënderimi i takon Allahut që më ushqeu me këtë dhe ma mundësoi pa asnjë fuqi e forcë timen,' i falen mëkatet e kaluara.\"\n— Tirmidhi"
}
