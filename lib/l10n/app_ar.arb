  "hadith0": "«أحب الأعمال إلى الله أدومها وإن قلّ.»\n— البخاري ومسلم",
  "hadith1": "«خذوا من الأعمال ما تطيقون، فإن خير الأعمال أدومه وإن قلّ.»\n— ابن ماجه",
  "hadith2": "«إذا مات ابن آدم انقطع عمله إلا من ثلاث: صدقة جارية، أو علم يُنتفع به، أو ولد صالح يدعو له.»\n— مسلم",
  "hadith3": "«من صلّى البَرْدَين دخل الجنة.»\n— البخاري",
  "hadith4": "«إن الله لا ينظر إلى صوركم وأموالكم، ولكن ينظر إلى قلوبكم وأعمالكم.»\n— مسلم",
  "hadith5": "«خير الناس أنفعهم للناس.»\n— الدارقطني",
  "hadith6": "«يسّروا ولا تعسّروا، وبشّروا ولا تنفّروا.»\n— البخاري",
  "hadith7": "«من سلك طريقاً يلتمس فيه علماً سهّل الله له به طريقاً إلى الجنة.»\n— مسلم",
  "hadith8": "«ما نقصت صدقة من مال.»\n— مسلم",
  "hadith9": "«المؤمن القوي خير وأحب إلى الله من المؤمن الضعيف، وفي كلٍّ خير.»\n— مسلم",
  "historyDayCompleted": "تم إنجاز {completed} من {total}",
  "settingsSchedule": "الجدول",
  "settingsAppearance": "المظهر",
  "settingsAboutTagline": "رفيقك اليومي في الدين",
  "settingsRolloverSub": "متى يبدأ اليوم الجديد",
  "hadith10": "\"من قال سبحان الله وبحمده في يوم مائة مرة حُطّت خطاياه وإن كانت مثل زبد البحر.\"\n— البخاري",
  "hadith11": "\"خير الدعاء دعاء يوم عرفة، وخير ما قلت أنا والنبيون من قبلي: لا إله إلا الله.\"\n— الترمذي",
  "hadith12": "\"من قرأ آية الكرسي دبر كل صلاة مكتوبة لم يمنعه من دخول الجنة إلا الموت.\"\n— النسائي",
  "hadith13": "\"الكلمة الطيبة صدقة.\"\n— البخاري ومسلم",
  "hadith14": "\"من كان يؤمن بالله واليوم الآخر فليقل خيرًا أو ليصمت.\"\n— البخاري ومسلم",
  "hadith15": "\"الساعي على الأرملة والمسكين كالمجاهد في سبيل الله.\"\n— البخاري",
  "hadith16": "\"تبسّمك في وجه أخيك صدقة.\"\n— الترمذي",
  "hadith17": "\"خيركم من تعلم القرآن وعلمه.\"\n— البخاري",
  "hadith18": "\"ما أكل أحد طعامًا قط خيرًا من أن يأكل من عمل يده.\"\n— البخاري",
  "hadith19": "\"إن الله رفيق يحب الرفق في الأمر كله.\"\n— البخاري ومسلم",
  "settingsAbout": "حول",
  "settingsVersion": "الإصدار",
  "settingsDeveloper": "المطور",
  "hadith20": "\"مَنْ صَامَ رَمَضَانَ إِيمَانًا وَاحْتِسَابًا غُفِرَ لَهُ مَا تَقَدَّمَ مِنْ ذَنْبِهِ.\"\n— البخاري ومسلم",
  "hadith21": "\"الصَّلاةُ عِمَادُ الدِّينِ.\"\n— البيهقي",
  "hadith22": "\"الدُّعَاءُ بَيْنَ الأَذَانِ وَالإِقَامَةِ لا يُرَدُّ.\"\n— أبو داود",
  "hadith23": "\"مَنْ بَنَى مَسْجِدًا لِلَّهِ بَنَى اللَّهُ لَهُ بَيْتًا فِي الجَنَّةِ.\"\n— البخاري ومسلم",
  "hadith24": "\"خَيْرُ صُفُوفِ الرِّجَالِ أَوَّلُهَا وَخَيْرُ صُفُوفِ النِّسَاءِ آخِرُهَا.\"\n— مسلم",
  "hadith25": "\"الصِّيَامُ جُنَّةٌ مِنَ النَّارِ.\"\n— النسائي",
  "hadith26": "\"مَنْ صَلَّى اثْنَتَيْ عَشْرَةَ رَكْعَةً تَطَوُّعًا بُنِيَ لَهُ بَيْتٌ فِي الجَنَّةِ.\"\n— مسلم",
  "hadith27": "\"الْمَاهِرُ بِالقُرْآنِ مَعَ السَّفَرَةِ الكِرَامِ البَرَرَةِ.\"\n— البخاري ومسلم",
  "hadith28": "\"طَلَبُ العِلْمِ فَرِيضَةٌ عَلَى كُلِّ مُسْلِمٍ.\"\n— ابن ماجه",
  "hadith29": "\"أَفْضَلُ الصَّدَقَةِ سَقْيُ المَاءِ.\"\n— أحمد",
  "hadith30": "\"مَنْ قَرَأَ سُورَةَ الكَهْفِ يَوْمَ الجُمُعَةِ أَضَاءَ لَهُ مِنَ النُّورِ مَا بَيْنَ الجُمُعَتَيْنِ.\"\n— الحاكم",
  "hadith31": "\"اتَّقِ اللَّهَ حَيْثُمَا كُنْتَ وَأَتْبِعِ السَّيِّئَةَ الحَسَنَةَ تَمْحُهَا.\"\n— الترمذي",
  "hadith32": "\"يَسِّرُوا وَلا تُعَسِّرُوا وَبَشِّرُوا وَلا تُنَفِّرُوا.\"\n— البخاري",
  "hadith33": "\"الطُّهُورُ شَطْرُ الإِيمَانِ.\"\n— مسلم",
  "hadith34": "\"أَحَبُّ النَّاسِ إِلَى اللَّهِ أَنْفَعُهُمْ لِلنَّاسِ.\"\n— الطبراني",
  "hadith35": "\"مَا نَقَصَتْ صَدَقَةٌ مِنْ مَالٍ.\"\n— مسلم",
  "hadith36": "\"خَيْرُكُمْ مَنْ تَعَلَّمَ القُرْآنَ وَعَلَّمَهُ.\"\n— البخاري",
  "hadith37": "\"مَنْ سَلَكَ طَرِيقًا يَلْتَمِسُ فِيهِ عِلْمًا سَهَّلَ اللَّهُ لَهُ طَرِيقًا إِلَى الجَنَّةِ.\"\n— مسلم",
  "hadith38": "\"لا يُؤْمِنُ أَحَدُكُمْ حَتَّى يُحِبَّ لأَخِيهِ مَا يُحِبُّ لِنَفْسِهِ.\"\n— البخاري ومسلم",
  "hadith39": "\"صَنَائِعُ المَعْرُوفِ تَقِي مَصَارِعَ السُّوءِ.\"\n— الطبراني",
  "hadith40": "\"مَنْ قَالَ سُبْحَانَ اللَّهِ وَبِحَمْدِهِ غُرِسَتْ لَهُ نَخْلَةٌ فِي الجَنَّةِ.\"\n— الترمذي",
  "hadith41": "\"إِنَّمَا الأَعْمَالُ بِالنِّيَّاتِ.\"\n— البخاري ومسلم",
  "hadith42": "\"مَنْ صَلَّى الفَجْرَ فِي جَمَاعَةٍ فَهُوَ فِي ذِمَّةِ اللَّهِ.\"\n— مسلم",
  "hadith43": "\"أَقْرَبُ مَا يَكُونُ العَبْدُ مِنْ رَبِّهِ وَهُوَ سَاجِدٌ فَأَكْثِرُوا الدُّعَاءَ.\"\n— مسلم",
  "hadith44": "\"الصَّبْرُ ضِيَاءٌ.\"\n— مسلم",
  "hadith45": "\"لا يَشْكُرُ اللَّهَ مَنْ لا يَشْكُرُ النَّاسَ.\"\n— أبو داود",
  "hadith46": "\"مَا مِنْ مُسْلِمٍ يَغْرِسُ غَرْسًا فَيَأْكُلُ مِنْهُ إِنْسَانٌ أَوْ طَيْرٌ إِلَّا كَانَ لَهُ صَدَقَةً.\"\n— البخاري",
  "hadith47": "\"خَيْرُكُمْ خَيْرُكُمْ لأَهْلِهِ.\"\n— الترمذي",
  "hadith48": "\"مَنْ كَظَمَ غَيْظًا وَهُوَ قَادِرٌ عَلَى أَنْ يُنْفِذَهُ دَعَاهُ اللَّهُ عَلَى رُؤُوسِ الخَلائِقِ.\"\n— أبو داود",
  "hadith49": "\"تَبَسُّمُكَ فِي وَجْهِ أَخِيكَ صَدَقَةٌ.\"\n— الترمذي",
  "hadith50": "«أحب الناس إلى الله أنفعهم للناس.»\n— الطبراني",
  "hadith51": "«من كظم غيظاً وهو قادر على أن يُنفذه دعاه الله على رؤوس الخلائق يوم القيامة حتى يخيّره من الحور ما شاء.»\n— الترمذي",
  "hadith52": "«باكروا بالصدقة فإن البلاء لا يتخطاها.»\n— الترمذي",
  "hadith53": "«لا تحقرنّ من المعروف شيئاً ولو أن تلقى أخاك بوجه طلق.»\n— مسلم",
  "hadith54": "«خيركم خيركم لأهله.»\n— الترمذي",
  "hadith55": "«من قرأ بالآيتين من آخر سورة البقرة في ليلة كفتاه.»\n— البخاري ومسلم",
  "hadith56": "«الدنيا متاع وخير متاعها المرأة الصالحة.»\n— مسلم",
  "hadith57": "«ثلاث دعوات لا تُردّ: دعوة الصائم، ودعوة الإمام العادل، ودعوة المظلوم.»\n— الترمذي",
  "hadith58": "«من صلّى عليّ صلاة واحدة صلّى الله عليه بها عشراً.»\n— مسلم",
  "hadith59": "«المسجد بيت كل تقيّ.»\n— الطبراني",
  "hadith60": "«من قال لا حول ولا قوة إلا بالله كانت له دواءً من تسعة وتسعين داءً أيسرها الهمّ.»\n— الحاكم",
  "hadith61": "«إن الله يحب إذا عمل أحدكم عملاً أن يتقنه.»\n— الطبراني",
  "hadith62": "«الجنة تحت أقدام الأمهات.»\n— النسائي",
  "hadith63": "«برّ الوالدين أعظم الأعمال الواجبة.»\n— البخاري",
  "hadith64": "«من شكر القليل أُعطي الكثير.»\n— البيهقي",
  "hadith65": "«المؤمن مرآة المؤمن.»\n— أبو داود",
  "hadith66": "«إن الصدق يهدي إلى البرّ وإن البرّ يهدي إلى الجنة.»\n— البخاري ومسلم",
  "hadith67": "«أدِّ الأمانة إلى من ائتمنك ولا تخن من خانك.»\n— أبو داود والترمذي",
  "hadith68": "«ما يصيب المسلم من نصب ولا وصب ولا همّ ولا حزن ولا أذى ولا غمّ حتى الشوكة يُشاكها إلا كفّر الله بها من خطاياه.»\n— البخاري ومسلم",
  "hadith69": "«دعوة المسلم لأخيه بظهر الغيب مستجابة.»\n— مسلم",
  "hadith70": "«من سأل الله الجنة ثلاث مرات قالت الجنة: اللهم أدخله الجنة.»\n— الترمذي",
  "hadith71": "«أفضل الصيام بعد رمضان شهر الله المحرّم.»\n— مسلم",
  "hadith72": "«من حجّ فلم يرفث ولم يفسق رجع كيوم ولدته أمه.»\n— البخاري ومسلم",
  "hadith73": "«العمرة إلى العمرة كفّارة لما بينهما.»\n— البخاري ومسلم",
  "hadith74": "«سابقوا إلى الخيرات.»\n— مسلم",
  "hadith75": "«ركعتا الفجر خير من الدنيا وما فيها.»\n— مسلم",
  "hadith76": "«من لزم الاستغفار جعل الله له من كل ضيق مخرجاً.»\n— أبو داود",
  "hadith77": "«لو أنكم تتوكلون على الله حق توكله لرزقكم كما يرزق الطير.»\n— الترمذي",
  "hadith78": "«من عاد مريضاً لم يزل في خُرفة الجنة حتى يرجع.»\n— مسلم",
  "hadith79": "«أفشوا السلام، وأطعموا الطعام، وصلّوا بالليل والناس نيام، تدخلوا الجنة بسلام.»\n— الترمذي",
  "hadith80": "«أحب الأعمال إلى الله أدومها وإن قلّ.»\n— البخاري",
  "hadith81": "«لا حسد إلا في اثنتين: رجل آتاه الله مالاً فسلّطه على هلكته في الحق، ورجل آتاه الله حكمةً فهو يقضي بها ويعلّمها.»\n— البخاري ومسلم",
  "hadith82": "«المرء على دين خليله فلينظر أحدكم من يخالل.»\n— أبو داود والترمذي",
  "hadith83": "«أكثروا ذكر الموت فإنه يمحص الذنوب.»\n— الترمذي",
  "hadith84": "«خياركم ألينكم قلوباً.»\n— الطبراني",
  "hadith85": "«لا يكلّف الله نفساً إلا وسعها.»\n— القرآن ٢:٢٨٦",
  "hadith86": "«من ستر مسلماً ستره الله يوم القيامة.»\n— البخاري ومسلم",
  "hadith87": "«كن في الدنيا كأنك غريب أو عابر سبيل.»\n— البخاري",
  "hadith88": "«من يسّر على معسر يسّر الله عليه في الدنيا والآخرة.»\n— مسلم",
  "hadith89": "«إنما الأعمال بالنيات.»\n— البخاري ومسلم",
  "hadith90": "«إيّاكم والظن فإن الظن أكذب الحديث.»\n— البخاري ومسلم",
  "hadith91": "«من ترك الكذب وهو باطل بُني له في رَبَض الجنة.»\n— أبو داود",
  "hadith92": "«أبواب الخير كثيرة: التسبيح، والتحميد، والصدقة، والأمر بالمعروف، وإماطة الأذى عن الطريق.»\n— مسلم",
  "hadith93": "«اجتمعوا على طعامكم واذكروا اسم الله يُبارَك لكم فيه.»\n— أبو داود",
  "hadith94": "«خير المجالس أوسعها.»\n— أبو داود",
  "hadith95": "«اعفوا يُعفَ عنكم.»\n— أحمد",
  "hadith96": "«اعقلها وتوكل.»\n— الترمذي",
  "hadith97": "«عجباً لأمر المؤمن إن أمره كله له خير.»\n— مسلم",
  "hadith98": "«المسلم أخو المسلم لا يظلمه ولا يخذله ولا يحقره.»\n— مسلم",
  "hadith99": "«أحب الكلام إلى الله: سبحان الله وبحمده، سبحان الله العظيم.»\n— البخاري ومسلم"
}
