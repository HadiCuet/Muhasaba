  "hadith53": "\"Usidharau jambo lolote jema, hata kukutana na ndugu yako kwa uso wenye tabasamu.\"\n— Muslim",
  "hadith54": "\"Bora wenu ni yule aliye bora kwa familia yake.\"\n— Tirmidhi",
  "hadith55": "\"Yeyote anayesoma aya mbili za mwisho za Sura Al-Baqarah usiku, zinamtosha.\"\n— Bukhari na Muslim",
  "hadith56": "\"Dunia ni starehe, na starehe bora zaidi ni mke mwema.\"\n— Muslim",
  "hadith57": "\"Dua tatu hazikataliwa: dua ya mfungaji, kiongozi mwadilifu, na mtu aliyedhulumiwa.\"\n— Tirmidhi",
  "hadith58": "\"Yeyote anayenitumia salawati mara moja, Mwenyezi Mungu anamtumia rehema mara kumi.\"\n— Muslim",
  "hadith65": "\"Muumini ni kioo cha muumini.\"\n— Abu Dawud",
  "hadith66": "\"Ukweli unaongoza kwenye wema, na wema unaongoza kwenye Pepo.\"\n— Bukhari na Muslim",
  "hadith67": "\"Rudisha amana kwa aliyekuamini, na usimusaliti aliyekusaliti.\"\n— Abu Dawud na Tirmidhi",
  "hadith68": "\"Hakuna uchovu, ugonjwa, huzuni, msongo, madhara au wasiwasi unaompata Muislamu, hata mchomo wa mwiba, isipokuwa Mwenyezi Mungu humfutia baadhi ya dhambi zake.\"\n— Bukhari na Muslim",
  "hadith69": "\"Dua ya Muislamu kwa ndugu yake ambaye hayupo daima inakubaliwa.\"\n— Muslim",
  "hadith70": "\"Yeyote anayemuomba Mwenyezi Mungu Pepo mara tatu, Pepo husema: Ee Mwenyezi Mungu, mwingize Peponi.\"\n— Tirmidhi",
  "hadith71": "\"Saumu bora zaidi baada ya Ramadani ni saumu ya mwezi wa Mwenyezi Mungu, Muharram.\"\n— Muslim",
  "hadith72": "\"Yeyote anayefanya Haji na hasemi maneno machafu wala hatendi dhambi, anarudi kama siku aliyozaliwa na mama yake.\"\n— Bukhari na Muslim",
  "hadith73": "\"Umra hadi Umra nyingine ni kafara ya dhambi zilizo kati yake.\"\n— Bukhari na Muslim",
  "hadith74": "\"Harakisheni kufanya matendo mema kabla ya kuja mitihani kama vipande vya usiku wa giza.\"\n— Muslim",
  "hadith75": "\"Rakaa mbili za Alfajiri ni bora kuliko dunia na vyote vilivyomo.\"\n— Muslim",
  "hadith77": "\"Kama mngemtegemea Mwenyezi Mungu kama inavyostahili, Angewapa riziki kama Anavyowapa ndege.\"\n— Tirmidhi",
  "hadith78": "\"Anayemtembelea mgonjwa anakuwa katika bustani ya Pepo hadi anarudi.\"\n— Muslim",
  "hadith79": "\"Enezeni salamu, lisheni wenye njaa, na salini usiku watu wanapokuwa wamelala — mtaingia Peponi kwa amani.\"\n— Tirmidhi",
  "hadith80": "\"Asiyeshukuru kwa watu hashukuru kwa Mwenyezi Mungu.\"\n— Tirmidhi",
  "hadith81": "\"Wivu hauruhusiwi isipokuwa katika mambo mawili: mtu aliyepewa mali na Mwenyezi Mungu naye akaitumia katika njia ya haki, na mtu aliyepewa hekima naye akahukumu na kufundisha nayo.\"\n— Bukhari na Muslim",
  "hadith82": "\"Mtu anafuata dini ya rafiki yake wa karibu, basi kila mmoja wenu aangalie anayemfanya rafiki.\"\n— Abu Dawud na Tirmidhi",
  "hadith85": "\"Anayeacha kitu kwa ajili ya Mwenyezi Mungu, Mwenyezi Mungu atambadilishia kitu bora zaidi.\"\n— Ahmad",
  "hadith86": "\"Anayeficha makosa ya Mwislamu, Mwenyezi Mungu ataficha makosa yake Siku ya Hukumu.\"\n— Bukhari na Muslim",
  "hadith87": "\"Kuwa katika dunia hii kana kwamba wewe ni mgeni au msafiri.\"\n— Bukhari",
  "hadith88": "\"Anayemfanyia urahisi mtu aliye katika ugumu, Mwenyezi Mungu atamfanyia urahisi duniani na akhera.\"\n— Muslim",
  "hadith89": "\"Malipo ya matendo yanategemea nia.\"\n— Bukhari na Muslim",
  "hadith90": "\"Jiepusheni na dhana, kwani dhana ni usemi wa uongo zaidi.\"\n— Bukhari na Muslim",
  "hadith93": "\"Kuleni pamoja na mtajeni jina la Mwenyezi Mungu, mtabarikiwa.\"\n— Abu Dawud",
  "hadith94": "\"Mkutano bora ni ule wenye wasaa zaidi.\"\n— Abu Dawud",
  "hadith95": "\"Sameheni na mtasamehewa.\"\n— Ahmad",
  "hadith96": "\"Mfunge ngamia wako kisha umtegemee Mwenyezi Mungu.\"\n— Tirmidhi",
  "hadith97": "\"Ni ajabu mambo ya muumini — kila kitu ni kheri kwake.\"\n— Muslim",
  "hadith98": "\"Mwislamu ni ndugu wa Mwislamu: hamdhulumu, hamtelekezi, wala hamdharau.\"\n— Muslim",
  "hadith20": "\"Anayefunga Ramadhani kwa imani na kutaraji thawabu, dhambi zake zilizopita zitasamehewa.\"\n— Bukhari na Muslim",
  "hadith22": "\"Dua kati ya adhana na iqama hairudiwi.\"\n— Abu Dawud",
  "hadith23": "\"Anayejenga msikiti kwa ajili ya Mwenyezi Mungu, Mwenyezi Mungu atamjengea nyumba Peponi.\"\n— Bukhari na Muslim",
  "hadith24": "\"Safu bora kwa wanaume ni za mbele, na safu bora kwa wanawake ni za nyuma.\"\n— Muslim",
  "hadith25": "\"Kufunga ni ngao dhidi ya Moto wa Jahannam.\"\n— Nasa'i",
  "hadith26": "\"Anayeswali rakaa kumi na mbili za sunna, atajengewa nyumba Peponi.\"\n— Muslim",
  "hadith27": "\"Aliye hodari katika Qurani atakuwa pamoja na malaika watukufu.\"\n— Bukhari na Muslim",
  "hadith29": "\"Sadaka bora ni kutoa maji ya kunywa.\"\n— Ahmad",
  "hadith30": "\"Anayemuondolea muumini shida, Mwenyezi Mungu atamwondolea shida Siku ya Hukumu.\"\n— Muslim",
  "hadith32": "\"Haya ni sehemu ya imani.\"\n— Bukhari na Muslim",
  "hadith34": "\"Anayesubiri, Mwenyezi Mungu atampa subira.\"\n— Bukhari na Muslim",
  "hadith36": "\"Hakuna yeyote kati yenu atakayeamini kweli kweli hadi ampendelee ndugu yake kile anachojipendea mwenyewe.\"\n— Bukhari na Muslim",
  "hadith37": "\"Walisheni wenye njaa, watembeleni wagonjwa, na waacheni huru mateka.\"\n— Bukhari",
  "hadith38": "\"Mtu mwenye nguvu si yule anayeshinda katika mieleka, bali ni yule anayejizuia wakati wa hasira.\"\n— Bukhari na Muslim",
  "hadith40": "\"Semeni 'SubhanAllah', 'Alhamdulillah', na 'Allahu Akbar' mara thelathini na tatu baada ya kila swala.\"\n— Muslim",
  "hadith41": "\"Dhikri bora ni La ilaha illallah.\"\n— Tirmidhi",
  "hadith42": "\"Kuna neema mbili ambazo watu wengi huzipoteza: afya na wakati wa ziada.\"\n— Bukhari",
  "hadith43": "\"Tumieni tano kabla ya tano: ujana kabla ya uzee, afya kabla ya ugonjwa, utajiri kabla ya umaskini, wakati wa ziada kabla ya shughuli, na uhai kabla ya kifo.\"\n— Hakim",
  "hadith44": "\"Anayesoma Suratul Ikhlas mara kumi, Mwenyezi Mungu atamjengea nyumba Peponi.\"\n— Ahmad",
  "hadith45": "\"Swala bora baada ya swala za faradhi ni swala ya usiku.\"\n— Muslim",
  "hadith46": "\"Sadaka inazima dhambi kama maji yanavyozima moto.\"\n— Tirmidhi",
  "hadith47": "\"Anayeunga udugu si yule anayerudisha, bali ni yule anayeendelea kuunga hata unapokatwa.\"\n— Bukhari",
  "hadith49": "\"Anayekula chakula na kusema: 'Sifa zote njema ni za Mwenyezi Mungu aliyenilisha hiki na kuniruzuku bila nguvu wala uwezo wowote kutoka kwangu,' dhambi zake zilizopita zitasamehewa.\"\n— Tirmidhi"
}
