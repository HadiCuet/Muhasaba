  "sundayFull": "یەکشەممە",
  "hadith0": "\"خۆشەویستترین کردار لای خوا ئەوانەن کە بەردەوام بن، تەنانەت گەر بچووکیش بن.\"\n— بوخاری و موسلیم",
  "hadith1": "\"کرداری چاک بکەن بەقەدری توانایان، چونکە باشترین کردار ئەوانەن کە بەردەوام بن تەنانەت گەر کەمیش بن.\"\n— ئیبن ماجە",
  "hadith2": "\"کاتێک کوڕی ئادەم دەمرێت، کردارەکانی دەوەستن جگە لە سێ: خێراتی بەردەوام، زانستی سوودبەخش، یان منداڵێکی چاک کە بۆی دوعا دەکات.\"\n— موسلیم",
  "hadith3": "\"هەرکەسێک دوو نوێژی فێنک (بەیانی و عەسر) بکات دەچێتە بەهەشتەوە.\"\n— بوخاری",
  "hadith4": "\"خوا سەیری ڕووخسارتان و سامانتان ناکات، بەڵکو سەیری دڵ و کردارتان دەکات.\"\n— موسلیم",
  "hadith5": "\"باشترین خەڵک ئەوانەن کە سوودیان بۆ خەڵک هەبێت.\"\n— دارەقوتنی",
  "hadith6": "\"ئاسان بکەن و قورس مەکەن؛ مژدە بدەن و خەڵکی مەتۆقێنن.\"\n— بوخاری",
  "hadith7": "\"هەرکەسێک ڕێگایەک بگرێت بۆ بەدەستهێنانی زانست، خوا ڕێگای بەهەشتی بۆ ئاسان دەکات.\"\n— موسلیم",
  "hadith8": "\"خێرات سامان کەم ناکاتەوە.\"\n— موسلیم",
  "hadith9": "\"باوەڕداری بەهێز باشتر و خۆشەویستترە لای خوا لە باوەڕداری لاواز، لەگەڵ ئەوەشدا لە هەردووکیاندا چاکە هەیە.\"\n— موسلیم",
  "historyDayCompleted": "{completed} ji {total} qediya",
  "settingsSchedule": "Bernameya dem",
  "settingsAppearance": "Xuyang",
  "settingsAboutTagline": "Hevkarê dînê te yê rojane",
  "settingsRolloverSub": "Roj kengî nû dibe",
  "hadith10": "\"Ew kesê ku di rojê de sed caran 'SubhanAllahi we bihamdihi' bêje, gunahên wî têne baxişandin heke wek kefa behrê bin jî.\"\n— Buxarî",
  "hadith11": "\"Duaya herî baş ya roja Erefeyê ye, û baştirîn gotina ku min û pêxemberên beriya min gotine ev e: La ilaha illallah.\"\n— Tirmizî",
  "hadith12": "\"Ew kes ku piştî her nimêja ferzê Ayetul-Kursiyê bixwîne, tiştek wî ji ketina bihuştê nahêle ji bilî mirinê.\"\n— Nesaî",
  "hadith13": "\"Gotina baş xêr e.\"\n— Buxarî & Muslim",
  "hadith14": "\"Ew kesê ku bi Xwedê û roja dawîn bawer dike, bila qala qenciyê bike an bêdeng be.\"\n— Buxarî & Muslim",
  "hadith15": "\"Ew kesê ku li jinebîyê û feqîr miqate dibe, mîna mûcahidê di rêya Xwedê de ye.\"\n— Buxarî",
  "hadith16": "\"Bişirîna te li rûyê birayê te xêr e.\"\n— Tirmizî",
  "hadith17": "\"Yê herî qenc di nav we de ew e ku Quranê hîn dibe û hîn dike.\"\n— Buxarî",
  "hadith18": "\"Kes xwarina ji ya ku bi destê xwe qezenc kiriye çêtir nexwariye.\"\n— Buxarî",
  "hadith19": "\"Xwedê nerm e û nermiyê di her tiştî de hez dike.\"\n— Buxarî & Muslim",
  "settingsAbout": "Derbarê",
  "settingsVersion": "Guherto",
  "settingsDeveloper": "Pêşvebir",
  "hadith50": "\"Kesên ku ji Xwedê re herî delal in, ew in ku ji bo kesên din herî bi kêr in.\"\n— Tebranî",
  "hadith51": "\"Kî hêrsa xwe kontrol bike dema ku karibe wê bi kar bîne, Xwedê wê roja Qiyametê li ber hemû mexlûqan gazî wî bike da ku xelata xwe hilbijêre.\"\n— Tirmizî",
  "hadith52": "\"Di dayîna xêrê de lez bikin, ji ber ku ew li ber belayê disekine.\"\n— Tirmizî",
  "hadith53": "\"Tu qenciyê piçûk nebîne, heta ku bi rûyekî geş birayê xwe bibîne jî.\"\n— Muslim",
  "hadith54": "\"Yê we yê herî baş, yê ku ji bo malbata xwe herî baş be.\"\n— Tirmizî",
  "hadith55": "\"Kî şevê du ayetên dawî yên Sûreya Baqarayê bixwîne, ew jê re bes in.\"\n— Buxarî û Muslim",
  "hadith56": "\"Dinya kedek e û kedê herî baş jina salih e.\"\n— Muslim",
  "hadith57": "\"Sê dua nayên red kirin: duaya yê ku rojî digire, serokê dadperwer û yê ku zulm lê hatiye kirin.\"\n— Tirmizî",
  "hadith58": "\"Kî carekê li ser min selawat bîne, Xwedê deh caran rehmeta xwe li wî dike.\"\n— Muslim",
  "hadith59": "\"Mizgeft mala her kesê pîroz e.\"\n— Tebranî",
  "hadith60": "\"Kî bibêje 'La hewle we la quwwete il-la bil-lah' — ev dermanê nod û neh nexweşiyan e, ya herî sivik jî xem e.\"\n— Hakim",
  "hadith61": "\"Xwedê hez dike ku gava hûn tiştekî dikin, wê bi awayekî herî baş bikin.\"\n— Tebranî",
  "hadith62": "\"Bihuşt di bin lingên dayikan de ye.\"\n— Nesaî",
  "hadith63": "\"Qenciya li dê û bavan peywira herî mezin e.\"\n— Buxarî",
  "hadith64": "\"Kî ji bo yê hindik şikir bike, pir jê re tê dayîn.\"\n— Beyhaqî",
  "hadith65": "\"Bawermend neynika bawermend e.\"\n— Ebû Dawûd",
  "hadith66": "\"Rastbêjî ber bi qenciyê ve dibe, û qencî ber bi Bihuştê ve dibe.\"\n— Buxarî û Muslim",
  "hadith67": "\"Emanetê bide wî yê ku bi te bawer kiriye, û xiyanetê li wî yê ku xiyanetê li te kiriye neke.\"\n— Ebû Dawûd û Tirmizî",
  "hadith68": "\"Tu westî, nexweşî, xem, kovan, êş an tengasiyê nagihîje Misilmanekî, tewra stêriyekê jî, bê ku Xwedê hin ji gunehên wî jê bibe.\"\n— Buxarî û Muslim",
  "hadith69": "\"Duaya Misilmanekî ji bo birayê xwe yê ku ne li ber wî ye her tim tê qebûl kirin.\"\n— Muslim",
  "hadith70": "\"Kî sê caran ji Xwedê Bihuştê bixwaze, Bihişt dibêje: Xwedayê min, wî bike nav Bihuştê.\"\n— Tirmizî",
  "hadith71": "\"Rojiya herî bi rûmet piştî Remezanê, rojiya meha Xwedê ya Muharremê ye.\"\n— Muslim",
  "hadith72": "\"Kî heccê bike û gotinên xirab nebêje û guneh nekeve, wek roja ku diya wî ew anîye dinyayê vedigere.\"\n— Buxarî û Muslim",
  "hadith73": "\"Umre heya umreya din keffareta gunehên di navbera wan de ye.\"\n— Buxarî û Muslim",
  "hadith74": "\"Di karên qenc de pêşbaziyê bikin.\"\n— Muslim",
  "hadith75": "\"دوو ڕەکاتی نوێژی بەیانی باشترن لە دونیا و هەموو ئەوەی تێیدایە.\"\n— موسلیم",
  "hadith76": "\"هەرکەسێک بەردەوام ئیستیغفار بکات، خودا لە هەموو تەنگانەیەک ڕێگای دەرچوونی بۆ دابین دەکات.\"\n— ئەبوو داوود",
  "hadith77": "\"ئەگەر ئێوە بە ڕاستی متمانەتان بە خودا دەکرد، ئەوا وەک باڵندەکان ڕزقتان دەدا.\"\n— تیرمیزی",
  "hadith78": "\"هەرکەسێک سەردانی نەخۆشێک بکات، تاکو دەگەڕێتەوە لە باخچەی بەهەشتدایە.\"\n— موسلیم",
  "hadith79": "\"سەلام بڵاو بکەنەوە، نان بدەن، و شەو نوێژ بکەن کاتێک خەڵکی خەوتوون — بە ئاشتییەوە دەچنە بەهەشتەوە.\"\n— تیرمیزی",
  "hadith80": "\"خۆشەویستترین کردەوە لای خودا ئەوەیە کە بەردەوام بێت، تەنانەت ئەگەر کەم بێت.\"\n— بوخاری",
  "hadith81": "\"بەغیلی تەنها لە دوو بارەوە ڕوادەبێت: کەسێک کە خودا سامانی داوە و لە ڕێگای ڕاستدا خەرجی دەکات، و کەسێک کە خودا دانایی داوە و پێی حوکم دەدات و فێری دەکات.\"\n— بوخاری و موسلیم",
  "hadith82": "\"مرۆڤ لەسەر ئایینی هاوڕێیەتی، بۆیە هەر یەکتان سەیری ئەوە بکات کە لەگەڵ کێ هاوڕێ دەبێت.\"\n— ئەبوو داوود و تیرمیزی",
  "hadith83": "\"زۆر بیری لە مردن بکەنەوە، چونکە دڵ پاک دەکات.\"\n— تیرمیزی",
  "hadith84": "\"باشترینتان ئەوەیە کە دڵی هەموویان نەرمتر بێت.\"\n— تەبەرانی",
  "hadith85": "\"خودا هیچ کەسێک بارگرانی لە توانای زیاتر ناکات.\"\n— قورئان ٢:٢٨٦",
  "hadith86": "\"هەرکەسێک کەموکوڕی موسلمانێک بشارێتەوە، خودا لە ڕۆژی قیامەت کەموکوڕییەکانی دادەپۆشێت.\"\n— بوخاری و موسلیم",
  "hadith87": "\"لەم دونیایەدا وەک بێگانەیەک بژی یان وەک ڕێبوارێک.\"\n— بوخاری",
  "hadith88": "\"هەرکەسێک ئاسانکاری بۆ کەسێکی تەنگانەدا بکات، خودا لە دونیا و ئاخیرەتدا ئاسانی بۆ دەکات.\"\n— موسلیم",
  "hadith89": "\"پاداشتی کردەوەکان بە نیەتەکان دادەنرێت.\"\n— بوخاری و موسلیم",
  "hadith90": "\"لە گومان دووربن، چونکە گومان درۆیینترین قسەیە.\"\n— بوخاری و موسلیم",
  "hadith91": "\"هەرکەسێک بۆ خاتری خودا درۆ بەجێبهێڵێت، تەنانەت لە پێکەنین، من بۆی قەسرێک لە لێواری بەهەشتدا دەسەلمێنم.\"\n— ئەبوو داوود",
  "hadith92": "\"دەروازەکانی چاکە زۆرن: تەسبیحی خودا، سوپاسی ئەو، سەدەقە، فەرمانی بە چاکە، و لابردنی زیانی ڕێگا.\"\n— موسلیم",
  "hadith93": "\"پێکەوە نان بخۆن و ناوی خودا ببێنن، بۆتان بەرەکەت دەبێت.\"\n— ئەبوو داوود",
  "hadith94": "\"باشترین کۆبوونەوە ئەوەیە کە فراوانتر بێت.\"\n— ئەبوو داوود",
  "hadith95": "\"لێبوردن بکەن، ئێوەش لێبوردن دەکرێت.\"\n— ئەحمەد",
  "hadith96": "\"وشترەکەت ببەستە پاشان متمانە بە خودا بکە.\"\n— تیرمیزی",
  "hadith97": "\"سەرسوڕمەزانە کاری باوەڕداری — هەموو شتێک بۆی باشە.\"\n— موسلیم",
  "hadith98": "\"موسلمان برای موسلمانە: ستەمی لێ ناکات، بەجێی ناهێڵێت، و سووکی ناکات.\"\n— موسلیم",
  "hadith99": "\"خۆشەویستترین قسە لای خودا: سوبحان ئاللە و بیحەمدیهی، سوبحان ئاللە ئەلعەزیم.\"\n— بوخاری و موسلیم",
  "hadith20": "\"Kî bi bawerî û bi hêviya xelatê Remezanê rojî bigire, gunehên wî yên berê têne baxişandin.\"\n— Buxarî û Muslim",
  "hadith21": "\"Nimêj stûna dînê ye.\"\n— Beyhaqî",
  "hadith22": "\"Duaya di navbera ezan û îqameyê de nayê redkirin.\"\n— Ebû Dawûd",
  "hadith23": "\"Kî ji bo Xwedê mizgeftek ava bike, Xwedê jî ji bo wî xaniyek li bihuştê ava dike.\"\n— Buxarî û Muslim",
  "hadith24": "\"Safên herî baş ji bo mêran yên pêşîn in, safên herî baş ji bo jinan jî yên paşîn in.\"\n— Muslim",
  "hadith25": "\"Rojî mertalek e ji agirê dojehê.\"\n— Nesaî",
  "hadith26": "\"Kî diwanzdeh rikatên sunnetê bixwîne, li bihuştê xaniyek ji bo wî tê avakirin.\"\n— Muslim",
  "hadith27": "\"Yê ku di xwendina Quranê de jêhatî be, dê bi milyaketên hêja re be.\"\n— Buxarî û Muslim",
  "hadith28": "\"Lêgerîna zanistê li ser her misilmanekî farz e.\"\n— Îbn Mace",
  "hadith29": "\"Xêra herî baş dayîna avê ye ku were vexwarin.\"\n— Ehmed",
  "hadith30": "\"Kî tengahiyek ji bawermendekî rake, Xwedê dê Roja Qiyametê tengahiyek ji wî rake.\"\n— Muslim",
  "hadith31": "\"Yên dilovan, Xwedayê herî Dilovan li wan dilovaniyê dike.\"\n— Ebû Dawûd û Tirmizî",
  "hadith32": "\"Şerm beşek ji baweriyê ye.\"\n— Buxarî û Muslim",
  "hadith33": "\"Paqijî nîvê baweriyê ye.\"\n— Muslim",
  "hadith34": "\"Kî sebir bike, Xwedê jê re sebir dide.\"\n— Buxarî û Muslim",
  "hadith35": "\"Dewlemendiya herî baş zimanê ku Xwedê bi bîr tîne ye.\"\n— Tebranî",
  "hadith36": "\"Kes ji we bi rastî bawer nake heta ku ji bo birayê xwe tiştê ku ji bo xwe dixwaze nexwaze.\"\n— Buxarî û Muslim",
  "hadith37": "\"Birçiyan têr bikin, nexweşan serdana bikin û girtîyan azad bikin.\"\n— Buxarî",
  "hadith38": "\"Yê bi hêz ne ew e ku di zordariyê de bi ser dikeve, lê ew e ku di dema hêrsê de xwe kontrol dike.\"\n— Buxarî û Muslim",
  "hadith39": "\"Kî tiştê di navbera çeneyê û lingên wî de biparêze, ez bihuştê jê re garantî dikim.\"\n— Buxarî",
  "hadith40": "\"Piştî her nimêjê sî û sê caran 'SubhanAllah', 'Elhemdulillah' û 'Allahu Ekber' bêjin.\"\n— Muslim",
  "hadith41": "\"Zikra herî baş La ilahe illallah e.\"\n— Tirmizî",
  "hadith42": "\"Du nîmet hene ku gelek kes wan winda dikin: tenduristî û dema vala.\"\n— Buxarî",
  "hadith43": "\"Pênc tiştan berî pênc tiştan bi kar bînin: ciwaniya xwe berî pîrbûnê, tenduristiya xwe berî nexweşiyê, dewlemendiya xwe berî xizaniyê, dema vala berî mijûliyê û jiyana xwe berî mirinê.\"\n— Hakim",
  "hadith44": "\"Kî Sûreya Îxlasê deh caran bixwîne, Xwedê li bihuştê xaniyek ji bo wî ava dike.\"\n— Ehmed",
  "hadith45": "\"Nimêja herî baş piştî farzê nimêja şevê ye.\"\n— Muslim",
  "hadith46": "\"Xêr gunahan vedimirandine wek ku av agir vedimirandine.\"\n— Tirmizî",
  "hadith47": "\"Yê ku xizmên xwe didomîne ne ew e ku bersivê dide, lê ew e ku dema têkilî têne qut kirin jî berdewam dike.\"\n— Buxarî",
  "hadith48": "\"Her kirina qenc xêr e.\"\n— Buxarî û Muslim",
  "hadith49": "\"Kî xwarinê bixwe û Elhemdulillah bêje, gunehên wî yên berê têne baxişandin.\"\n— Tirmizî"
}
