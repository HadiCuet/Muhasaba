# Copy this file to fastlane/.env (gitignored) and fill in real values.
#
# Create the key: App Store Connect -> Users and Access -> Integrations ->
# App Store Connect API -> generate a Team Key with the "App Manager" role.
# Download the .p8 ONCE and place it at fastlane/.keys/ (gitignored).
# Full steps: docs/fastlane-setup.md

ASC_KEY_ID=ABC123XYZ
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_KEY_FILEPATH=fastlane/.keys/AuthKey_ABC123XYZ.p8

# Apple Developer Portal Team ID (10 chars) — developer.apple.com -> Membership.
ASC_TEAM_ID=XXXXXXXXXX
